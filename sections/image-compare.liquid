{%- style -%}
  /* ── Dynamic schema variables ── */
  #ImageCompare-{{ section.id }} {
    --cs-bg:            {{ section.settings.bg_color }};
    --cs-heading-color: {{ section.settings.heading_color }};
    --cs-text-color:    {{ section.settings.text_color }};
    --cs-handle-color:  {{ section.settings.handle_color }};
    --cs-label-bg:      {{ section.settings.label_bg }};
    --cs-label-color:   {{ section.settings.label_color }};
    --cs-radius:        {{ section.settings.corner_radius }}px;
    --cs-split:         {{ section.settings.slider_position }}%;
    --pt:               {{ section.settings.padding_top }}px;
    --pb:               {{ section.settings.padding_bottom }}px;
  }
  @media screen and (max-width: 749px) {
    #ImageCompare-{{ section.id }} {
      --pt: {{ section.settings.mobile_padding_top }}px;
      --pb: {{ section.settings.mobile_padding_bottom }}px;
    }
  }

  /* ── Section wrapper ── */
  .cs-section {
    background-color: var(--cs-bg, #ffffff);
    padding-top:    var(--pt, 60px);
    padding-bottom: var(--pb, 60px);
  }

  /* ── Optional heading block ── */
  .cs-header {
    margin-bottom: 3.2rem;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .cs-header--left   { align-items: flex-start; text-align: left;   }
  .cs-header--center { align-items: center;     text-align: center; }
  .cs-header--right  { align-items: flex-end;   text-align: right;  }

  /* ── Web component display ── */
  image-compare { display: block; }

  /* ── Comparison wrapper ── */
  .cs-wrap {
    position: relative;
    overflow: hidden;
    border-radius: var(--cs-radius, 12px);
    cursor: col-resize;
    user-select: none;
    -webkit-user-select: none;
    touch-action: none;
  }

  /* Aspect ratio options */
  .cs-wrap--21-9 { aspect-ratio: 21 / 9; }
  .cs-wrap--16-9 { aspect-ratio: 16 / 9; }
  .cs-wrap--4-3  { aspect-ratio: 4  / 3; }
  .cs-wrap--3-2  { aspect-ratio: 3  / 2; }
  .cs-wrap--1-1  { aspect-ratio: 1  / 1; }
  .cs-wrap--3-4  { aspect-ratio: 3  / 4; }

  /* ── Image layers ── */
  .cs-layer {
    position: absolute;
    inset: 0;
  }

  /* Both images use position:absolute so they reference the same
     containing block (.cs-layer) and are guaranteed pixel-perfect overlap */
  .cs-layer img,
  .cs-layer .placeholder-svg {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    pointer-events: none;
    -webkit-user-drag: none;
  }

  /* Before — base, always fully visible underneath */
  .cs-layer--before { z-index: 1; }

  /* After — clipped from the right; reveals left portion up to --cs-split */
  .cs-layer--after {
    z-index: 2;
    clip-path: inset(0 calc(100% - var(--cs-split, 50%)) 0 0);
  }

  /* ── Labels ── */
  .cs-label {
    position: absolute;
    bottom: 1.6rem;
    padding: 0.4rem 1.2rem;
    border-radius: 10rem;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background-color: var(--cs-label-bg, rgba(0, 0, 0, 0.6));
    color: var(--cs-label-color, #ffffff);
    pointer-events: none;
    white-space: nowrap;
  }

  /* Before label sits on the right (where before image is visible) */
  .cs-label--before { right: 1.6rem; }
  /* After label sits on the left (within the revealed after region)  */
  .cs-label--after  { left:  1.6rem; }

  /* ── Drag handle ── */
  .cs-handle {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--cs-split, 50%);
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 4.4rem;
    cursor: col-resize;
    touch-action: none;
  }

  .cs-handle:focus          { outline: none; }
  .cs-handle:focus-visible .cs-handle__btn {
    outline: 3px solid #005fcc;
    outline-offset: 3px;
  }

  /* Vertical line segments above and below the button */
  .cs-handle__line {
    flex: 1;
    width: 2px;
    background-color: var(--cs-handle-color, #ffffff);
    box-shadow: 0 0 6px rgba(0, 0, 0, 0.35);
  }

  /* Circular drag button */
  .cs-handle__btn {
    flex-shrink: 0;
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    background-color: var(--cs-handle-color, #ffffff);
    color: #111111;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.28);
    transition: transform 0.15s ease;
  }

  .cs-handle:active .cs-handle__btn { transform: scale(1.12); }

  /* ── Mobile (≤ 749px) ── */
  @media screen and (max-width: 749px) {
    .cs-header { margin-bottom: 2.4rem; }

    .cs-label {
      font-size: 1.1rem;
      padding: 0.3rem 0.9rem;
      bottom: 1.2rem;
    }
    .cs-label--before { right: 1.2rem; }
    .cs-label--after  { left:  1.2rem; }

    .cs-handle__btn {
      width: 3.6rem;
      height: 3.6rem;
    }
  }
{%- endstyle -%}

<script>
  /* Guard prevents re-registration if section appears multiple times */
  if (!customElements.get('image-compare')) {
    class ImageCompare extends HTMLElement {
      connectedCallback() {
        this._wrap   = this.querySelector('[data-cs-wrap]');
        this._handle = this.querySelector('[data-cs-handle]');
        if (!this._wrap || !this._handle) return;

        /* Initialise split from data attribute — keeps JS and CSS in sync */
        this._split = parseFloat(this.dataset.split || 50);
        this._setSplit(this._split);

        /* Mouse — mousedown on the full wrap for click-to-jump + drag */
        this._wrap.addEventListener('mousedown', this._onMouseDown.bind(this));

        /* Touch — passive:false so we can preventDefault immediately,
           blocking browser scroll before the first touchmove fires     */
        this._wrap.addEventListener('touchstart', this._onTouchStart.bind(this), { passive: false });

        /* Keyboard — arrow keys, Home, End */
        this._handle.addEventListener('keydown', this._onKeyDown.bind(this));
      }

      disconnectedCallback() {
        /* Nothing persistent to clean up; document listeners are
           added per-drag and removed immediately on pointerup/touchend */
      }

      /* ── Helpers ──────────────────────────────────────────── */

      _pct(clientX) {
        const r = this._wrap.getBoundingClientRect();
        return Math.max(0, Math.min(100, (clientX - r.left) / r.width * 100));
      }

      _setSplit(pct) {
        this._split = pct;
        this._wrap.style.setProperty('--cs-split', pct + '%');
        this._handle.setAttribute('aria-valuenow', Math.round(pct));
      }

      /* ── Mouse ────────────────────────────────────────────── */

      _onMouseDown(e) {
        e.preventDefault();
        this._setSplit(this._pct(e.clientX));

        const onMove = (e) => this._setSplit(this._pct(e.clientX));
        const onUp   = () => {
          document.removeEventListener('mousemove', onMove);
          document.removeEventListener('mouseup',   onUp);
        };

        document.addEventListener('mousemove', onMove);
        document.addEventListener('mouseup',   onUp);
      }

      /* ── Touch ────────────────────────────────────────────── */

      _onTouchStart(e) {
        /* Prevent page scroll for the entire drag gesture */
        e.preventDefault();
        this._setSplit(this._pct(e.touches[0].clientX));

        const onMove = (e) => {
          e.preventDefault();
          this._setSplit(this._pct(e.touches[0].clientX));
        };
        const onEnd = () => {
          document.removeEventListener('touchmove', onMove);
          document.removeEventListener('touchend',  onEnd);
        };

        document.addEventListener('touchmove', onMove, { passive: false });
        document.addEventListener('touchend',  onEnd);
      }

      /* ── Keyboard ─────────────────────────────────────────── */

      _onKeyDown(e) {
        const step = e.shiftKey ? 10 : 5;
        switch (e.key) {
          case 'ArrowLeft':  e.preventDefault(); this._setSplit(Math.max(0,   this._split - step)); break;
          case 'ArrowRight': e.preventDefault(); this._setSplit(Math.min(100, this._split + step)); break;
          case 'Home':       e.preventDefault(); this._setSplit(0);   break;
          case 'End':        e.preventDefault(); this._setSplit(100); break;
        }
      }
    }

    customElements.define('image-compare', ImageCompare);
  }
</script>

<section id="ImageCompare-{{ section.id }}" class="cs-section">
  <div class="custom-page-width">

    {%- if section.settings.heading != blank or section.settings.description != blank -%}
      <div class="cs-header cs-header--{{ section.settings.text_alignment }}">
        {%- if section.settings.heading != blank -%}
          <h2 class="{{ section.settings.heading_size }}" style="color: var(--cs-heading-color);">
            {{ section.settings.heading | escape }}
          </h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="{{ section.settings.desc_size }}" style="color: var(--cs-text-color);">
            {{ section.settings.description | escape }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <image-compare data-split="{{ section.settings.slider_position }}">
      <div
        class="cs-wrap cs-wrap--{{ section.settings.aspect_ratio }}"
        data-cs-wrap
      >

        <!-- Before — base layer, always fully visible -->
        <div class="cs-layer cs-layer--before">
          {%- if section.settings.before_image != blank -%}
            {{
              section.settings.before_image
              | image_url: width: 1400
              | image_tag:
                widths: '400, 600, 800, 1000, 1200, 1400',
                sizes: '(min-width: 750px) 80vw, 100vw',
                loading: 'lazy',
                alt: section.settings.before_image.alt
            }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
          {%- if section.settings.show_labels and section.settings.before_label_text != blank -%}
            <span class="cs-label cs-label--before">
              {{ section.settings.before_label_text | escape }}
            </span>
          {%- endif -%}
        </div>

        <!-- After — clipped layer, revealed left-to-right by the slider -->
        <div class="cs-layer cs-layer--after">
          {%- if section.settings.after_image != blank -%}
            {{
              section.settings.after_image
              | image_url: width: 1400
              | image_tag:
                widths: '400, 600, 800, 1000, 1200, 1400',
                sizes: '(min-width: 750px) 80vw, 100vw',
                loading: 'lazy',
                alt: section.settings.after_image.alt
            }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
          {%- if section.settings.show_labels and section.settings.after_label_text != blank -%}
            <span class="cs-label cs-label--after">
              {{ section.settings.after_label_text | escape }}
            </span>
          {%- endif -%}
        </div>

        <!-- Drag handle -->
        <div
          class="cs-handle"
          data-cs-handle
          role="slider"
          aria-label="Compare before and after images"
          aria-valuemin="0"
          aria-valuemax="100"
          aria-valuenow="{{ section.settings.slider_position }}"
          tabindex="0"
        >
          <div class="cs-handle__line"></div>
          <div class="cs-handle__btn" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
              <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/>
            </svg>
          </div>
          <div class="cs-handle__line"></div>
        </div>

      </div>
    </image-compare>

  </div>
</section>

{% schema %}
{
  "name": "Image Compare",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "font-55-37", "label": "Large (55/37px)"  },
        { "value": "font-44-34", "label": "Medium (44/34px)" },
        { "value": "font-30-24", "label": "Small (30/24px)"  }
      ],
      "default": "font-30-24"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "desc_size",
      "label": "Description size",
      "options": [
        { "value": "desc-large",  "label": "Large (22/18px)"  },
        { "value": "desc-normal", "label": "Normal (18/16px)" },
        { "value": "desc-small",  "label": "Small (16/14px)"  }
      ],
      "default": "desc-normal"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left",   "label": "Left"   },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right"  }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Before Image"
    },
    {
      "type": "image_picker",
      "id": "before_image",
      "label": "Before image"
    },
    {
      "type": "header",
      "content": "After Image"
    },
    {
      "type": "image_picker",
      "id": "after_image",
      "label": "After image"
    },
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "range",
      "id": "slider_position",
      "label": "Default slider position",
      "info": "0 = show only Before · 100 = show only After",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "checkbox",
      "id": "show_labels",
      "label": "Show labels",
      "default": true
    },
    {
      "type": "text",
      "id": "before_label_text",
      "label": "Before label",
      "default": "Before"
    },
    {
      "type": "text",
      "id": "after_label_text",
      "label": "After label",
      "default": "After"
    },
    {
      "type": "color",
      "id": "label_bg",
      "label": "Label background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "handle_color",
      "label": "Handle color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        { "value": "21-9", "label": "21:9 — Ultrawide"  },
        { "value": "16-9", "label": "16:9 — Widescreen" },
        { "value": "4-3",  "label": "4:3 — Standard"    },
        { "value": "3-2",  "label": "3:2 — Photography" },
        { "value": "1-1",  "label": "1:1 — Square"      },
        { "value": "3-4",  "label": "3:4 — Portrait"    }
      ],
      "default": "16-9"
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Desktop padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Desktop padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile padding top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile padding bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#444444"
    }
  ],
  "presets": [
    {
      "name": "Image Compare"
    }
  ]
}
{% endschema %}
