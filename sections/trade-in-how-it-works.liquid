{% liquid
  assign heading_line_1 = section.settings.heading_line_1
  assign heading_highlight = section.settings.heading_highlight

  assign section_bg_color = section.settings.section_bg_color
  assign heading_color = section.settings.heading_color
  assign highlight_color = section.settings.highlight_color
  assign timeline_color = section.settings.timeline_color
  assign step_circle_bg = section.settings.step_circle_bg
  assign step_circle_text = section.settings.step_circle_text
  assign step_title_color = section.settings.step_title_color
  assign step_description_color = section.settings.step_description_color

  assign content_max_width = section.settings.content_max_width


  assign section_padding_top = section.settings.section_padding_top
  assign section_padding_bottom = section.settings.section_padding_bottom
  assign section_padding_horizontal = section.settings.section_padding_horizontal

  assign section_padding_top_mobile = section.settings.section_padding_top_mobile
  assign section_padding_bottom_mobile = section.settings.section_padding_bottom_mobile
  assign section_padding_horizontal_mobile = section.settings.section_padding_horizontal_mobile

  assign heading_size_desktop = section.settings.heading_size_desktop
  assign heading_size_mobile = section.settings.heading_size_mobile
  assign heading_gap_desktop = section.settings.heading_gap_desktop
  assign heading_gap_mobile = section.settings.heading_gap_mobile

  assign steps_max_width_desktop = section.settings.steps_max_width_desktop
  assign steps_gap_desktop = section.settings.steps_gap_desktop
  assign steps_gap_mobile = section.settings.steps_gap_mobile

  assign rail_width_desktop = section.settings.rail_width_desktop
  assign rail_width_mobile = section.settings.rail_width_mobile
  assign circle_size_desktop = section.settings.circle_size_desktop
  assign circle_size_mobile = section.settings.circle_size_mobile
  assign line_width = section.settings.line_width

  assign step_title_size_desktop = section.settings.step_title_size_desktop
  assign step_title_size_mobile = section.settings.step_title_size_mobile
  assign step_description_size_desktop = section.settings.step_description_size_desktop
  assign step_description_size_mobile = section.settings.step_description_size_mobile

  assign step_gap_desktop = section.settings.step_gap_desktop
  assign step_gap_mobile = section.settings.step_gap_mobile
  assign rail_content_gap_desktop = section.settings.rail_content_gap_desktop
  assign rail_content_gap_mobile = section.settings.rail_content_gap_mobile

  assign has_heading = false
  if heading_line_1 != blank or heading_highlight != blank
    assign has_heading = true
  endif
%}

{{ 'section-trade-in-how-it-works.css' | asset_url | stylesheet_tag }}

<section
  id="trade-in-how-it-works-{{ section.id }}"
  class="trade-in-how-it-works"
  style="
    --trade-in-how-it-works-bg: {{ section_bg_color }};
    --trade-in-how-it-works-heading-color: {{ heading_color }};
    --trade-in-how-it-works-highlight-color: {{ highlight_color }};
    --trade-in-how-it-works-timeline-color: {{ timeline_color }};
    --trade-in-how-it-works-step-circle-bg: {{ step_circle_bg }};
    --trade-in-how-it-works-step-circle-text: {{ step_circle_text }};
    --trade-in-how-it-works-step-title-color: {{ step_title_color }};
    --trade-in-how-it-works-step-description-color: {{ step_description_color }};

    --trade-in-how-it-works-content-max-width: {{ content_max_width }}px;

    --trade-in-how-it-works-padding-top: {{ section_padding_top }}px;
    --trade-in-how-it-works-padding-bottom: {{ section_padding_bottom }}px;
    --trade-in-how-it-works-padding-horizontal: {{ section_padding_horizontal }}px;

    --trade-in-how-it-works-padding-top-mobile: {{ section_padding_top_mobile }}px;
    --trade-in-how-it-works-padding-bottom-mobile: {{ section_padding_bottom_mobile }}px;
    --trade-in-how-it-works-padding-horizontal-mobile: {{ section_padding_horizontal_mobile }}px;

    --trade-in-how-it-works-heading-size-desktop: {{ heading_size_desktop }}px;
    --trade-in-how-it-works-heading-size-mobile: {{ heading_size_mobile }}px;
    --trade-in-how-it-works-heading-gap-desktop: {{ heading_gap_desktop }}px;
    --trade-in-how-it-works-heading-gap-mobile: {{ heading_gap_mobile }}px;

    --trade-in-how-it-works-steps-max-width-desktop: {{ steps_max_width_desktop }}px;
    --trade-in-how-it-works-steps-gap-desktop: {{ steps_gap_desktop }}px;
    --trade-in-how-it-works-steps-gap-mobile: {{ steps_gap_mobile }}px;

    --trade-in-how-it-works-rail-width-desktop: {{ rail_width_desktop }}px;
    --trade-in-how-it-works-rail-width-mobile: {{ rail_width_mobile }}px;
    --trade-in-how-it-works-circle-size-desktop: {{ circle_size_desktop }}px;
    --trade-in-how-it-works-circle-size-mobile: {{ circle_size_mobile }}px;
    --trade-in-how-it-works-line-width: {{ line_width }}px;

    --trade-in-how-it-works-step-title-size-desktop: {{ step_title_size_desktop }}px;
    --trade-in-how-it-works-step-title-size-mobile: {{ step_title_size_mobile }}px;
    --trade-in-how-it-works-step-description-size-desktop: {{ step_description_size_desktop }}px;
    --trade-in-how-it-works-step-description-size-mobile: {{ step_description_size_mobile }}px;

    --trade-in-how-it-works-step-gap-desktop: {{ step_gap_desktop }}px;
    --trade-in-how-it-works-step-gap-mobile: {{ step_gap_mobile }}px;
    --trade-in-how-it-works-rail-content-gap-desktop: {{ rail_content_gap_desktop }}px;
    --trade-in-how-it-works-rail-content-gap-mobile: {{ rail_content_gap_mobile }}px;
  "
>
  <div class="trade-in-how-it-works__inner">
    <div class="trade-in-how-it-works__container">
      {% if has_heading %}
        <div class="trade-in-how-it-works__intro">
          <h2 class="trade-in-how-it-works__heading">
            {% if heading_line_1 != blank %}
              <span class="trade-in-how-it-works__heading-text">{{ heading_line_1 }}</span>
            {% endif %}
            {% if heading_highlight != blank %}
              <span class="trade-in-how-it-works__heading-text trade-in-how-it-works__heading-text--highlight">{{ heading_highlight }}</span>
            {% endif %}
          </h2>
        </div>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <div class="trade-in-how-it-works__steps">
          <div class="trade-in-how-it-works__steps-rail" aria-hidden="true"></div>

          {% for block in section.blocks %}
            {% liquid
              assign step_number = block.settings.step_number
              assign step_title = block.settings.step_title
              assign step_description = block.settings.step_description
            %}

            {% if step_title != blank or step_description != blank %}
              <article class="trade-in-how-it-works__step" {{ block.shopify_attributes }}>
                <div class="trade-in-how-it-works__step-rail">
                  {% if step_number != blank %}
                    <div class="trade-in-how-it-works__step-circle">
                      {{ step_number }}
                    </div>
                  {% endif %}
                </div>

                <div class="trade-in-how-it-works__step-content">
                  {% if step_title != blank %}
                    <h3 class="trade-in-how-it-works__step-title">
                      {{ step_title }}
                    </h3>
                  {% endif %}

                  {% if step_description != blank %}
                    <div class="trade-in-how-it-works__step-description rte">
                      {{ step_description }}
                    </div>
                  {% endif %}
                </div>
              </article>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

