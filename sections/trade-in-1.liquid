<section class="stats-section-{{ section.id }}">
  <div class="stats-container">

    {% if section.settings.heading != blank %}
      <h2 class="stats-heading">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    <div class="stats-grid">
      {% for block in section.blocks %}
        <div class="stats-item" {{ block.shopify_attributes }}>
          <div class="stats-number">
            {{ block.settings.number }}
          </div>

          <div class="stats-subtitle">
            {{ block.settings.subtitle }}
          </div>
        </div>
      {% endfor %}
    </div>

  </div>
</section>

<style>

.stats-section-{{ section.id }}{
  background:#111111;
  padding:60px 20px;
  text-align:center;
}

.stats-section-{{ section.id }} .stats-container{
  max-width:1200px;
  margin:auto;
}

.stats-section-{{ section.id }} .stats-heading{
  font-size:30px;
  color:rgba(255,255,255,0.5);
  font-weight:500;
  line-height: 110%;
  letter-spacing:0.02em;
  margin-bottom:30px;
}

.stats-section-{{ section.id }} .stats-grid{
  display:flex;
  justify-content:center;
  gap:50px;
  flex-wrap:wrap;
}

.stats-section-{{ section.id }} .stats-number{
  color:#FFC200;
  font-size:36px;
  font-weight:900;
  line-height: 110%;
  letter-spacing: -0.03em;
}

.stats-section-{{ section.id }} .stats-subtitle{
  color:#ffffff;
  font-size:18px;
  margin-top:5px;
  letter-spacing: 0em;
}

@media(max-width:768px){

  .stats-section-{{ section.id }}{
    padding:30px 20px;
  }

  .stats-section-{{ section.id }} .stats-heading{
    font-size:16px;
    margin-bottom:15px;
  }

  .stats-section-{{ section.id }} .stats-grid{
    gap:15px;
    grid-template-columns: 1fr 1fr 1fr;
    display: grid;
  }

  .stats-section-{{ section.id }} .stats-number{
    font-size:30px;
  }

  .stats-section-{{ section.id }} .stats-subtitle{
    font-size:16px;
    line-height: 120%;
  }

}

</style>

{% schema %}
{
  "name": "Trade In 1",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "THE NUMBERS SPEAK FOR THEMSELVES"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "350K+"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "WATCHES SOLD"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trade In 1",
      "blocks": [
        { "type": "stat" },
        { "type": "stat" },
        { "type": "stat" }
      ]
    }
  ]
}
{% endschema %}