<script>
let timeout;

function updateViews() {
  const elements = document.querySelectorAll(".number-views");

  elements.forEach(el => {
    if (!el.dataset.updated) {
      const randomNumber = Math.floor(Math.random() * 60) + 40;
      el.textContent = randomNumber;
      el.dataset.updated = "true";
      console.log("Updated:", randomNumber);
    }
  });
}

document.addEventListener("DOMContentLoaded", function() {
  updateViews();

  const observer = new MutationObserver(function() {
    clearTimeout(timeout);
    timeout = setTimeout(updateViews, 200);
  });

  observer.observe(document.body, {
    childList: true,
    subtree: true
  });
});
</script>