                      {% else %}
                        {%- for product in recommendations.products -%}
                          {%- if shown_products_count >= 6 -%}
                            {%- break -%}
                          {%- endif -%}
                          {%- assign matching_product = cart.items | where: 'product_id', product.id -%}
                          {%- if matching_product.size == 0 -%}
                            {%- assign shown_products_count = shown_products_count | plus: 1 -%}
                            {%- render 'product-item-minicart', product: product, reduced_content: true, reduced_font_size: true, hide_secondary_image: true, sizes_attribute: '(max-width: 740px) 65px, 92px' -%}
                          {%- endif -%}
