                            {%- if matching_product.size == 0 -%}
                              {%- render 'product-item-minicart', product: recommended_product, reduced_content: true, reduced_font_size: true, hide_secondary_image: true, sizes_attribute: '(max-width: 740px) 65px, 92px' -%}
                            {%- endif -%}
                          {%- endif -%}
