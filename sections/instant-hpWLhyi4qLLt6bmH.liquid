      <script>
        document.addEventListener('DOMContentLoaded', function () {
          // Eliminar controles de video
          document.querySelectorAll('video.instant-video__player').forEach((video) => {
            video.removeAttribute('controls');
          });

          document.querySelectorAll('a.buy-now-instant').forEach((link) => {
            // Crear el nuevo elemento <p>
            const p = document.createElement('p');

            // Copiar todos los atributos
            for (const attr of link.attributes) {
              p.setAttribute(attr.name, attr.value);
            }

            // Copiar contenido
            p.innerHTML = link.innerHTML;
            p.style.cursor = 'pointer';

            // Reemplazar <a> por <p>
            link.parentNode.replaceChild(p, link);

            // Prevenir preload en hover
            p.addEventListener(
              'mouseover',
              (e) => {
                e.stopImmediatePropagation();
              },
              true,
            );

            // Click: agregar producto principal al carrito y redirigir a checkout
            p.addEventListener('click', function (e) {
              e.preventDefault();

              const variantId = p.getAttribute('data-instant-action-variant-id');
              if (!variantId) {
                console.error('No se encontró el data-instant-action-variant-id');
                return;
              }

              fetch('/cart/add.js', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                  Accept: 'application/json',
                },
                body: JSON.stringify({
                  id: variantId,
                  quantity: 1,
                }),
              })
                .then((res) => res.json())
                .then((data) => {
                  // Espera breve para que Dr Free Gift agregue el regalo
                  setTimeout(() => {
                    window.location.href = '/checkout';
                  }, 500); // Puedes ajustar si ves que no da tiempo
                })
                .catch((err) => {
                  console.error('Error al agregar al carrito:', err);
                });
            });
          });
        });
      </script></div
