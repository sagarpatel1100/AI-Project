{{ 'section-marquee.css' | asset_url | stylesheet_tag }}
<script src="{{ 'marquee-section.js' | asset_url }}" defer="defer"></script>

{%- assign letter_spacing_em = section.settings.letter_spacing | divided_by: 100.0 -%}

{%- style -%}
  #Marquee-{{ section.id }} {
    --marquee-bg:                  {{ section.settings.bg_color }};
    --marquee-border-color:        {{ section.settings.border_color }};
    --marquee-border-width:        {{ section.settings.border_width }}px;
    --marquee-gap:                 {{ section.settings.item_gap }}px;
    --marquee-speed:               {{ section.settings.speed }}s;
    --marquee-letter-spacing:      {{ letter_spacing_em }}em;
    --marquee-padding-top:         {{ section.settings.padding_top }}px;
    --marquee-padding-bottom:      {{ section.settings.padding_bottom }}px;
    --marquee-img-height:          {{ section.settings.image_height }}px;
    --marquee-img-height-mobile:   {{ section.settings.image_height_mobile }}px;
    --marquee-heading-gap:         {{ section.settings.heading_gap }}px;
    --marquee-mobile-padding-top:    {{ section.settings.mobile_padding_top }}px;
    --marquee-mobile-padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
  }
{%- endstyle -%}

<div
  id="Marquee-{{ section.id }}"
  class="marquee-section{% if section.settings.show_edge_fade %} marquee-section--fade{% endif %}"
>

  {%- if section.settings.show_border_top -%}
    <div class="marquee-section__border"></div>
  {%- endif -%}

  {%- if section.settings.heading != blank -%}
    <div class="marquee-section__heading-wrap marquee-heading-align--{{ section.settings.heading_alignment }}">
      {%- case section.settings.heading_tag -%}
        {%- when 'h1' -%}
          <h1
            class="marquee-section__heading {{ section.settings.heading_size }}{% if section.settings.heading_underline %} marquee-section__heading--underline{% endif %}"
            style="color:{{ section.settings.heading_color }};font-weight:{{ section.settings.heading_weight }};"
          >{{ section.settings.heading | escape }}</h1>
        {%- when 'h2' -%}
          <h2
            class="marquee-section__heading {{ section.settings.heading_size }}{% if section.settings.heading_underline %} marquee-section__heading--underline{% endif %}"
            style="color:{{ section.settings.heading_color }};font-weight:{{ section.settings.heading_weight }};"
          >{{ section.settings.heading | escape }}</h2>
        {%- when 'h3' -%}
          <h3
            class="marquee-section__heading {{ section.settings.heading_size }}{% if section.settings.heading_underline %} marquee-section__heading--underline{% endif %}"
            style="color:{{ section.settings.heading_color }};font-weight:{{ section.settings.heading_weight }};"
          >{{ section.settings.heading | escape }}</h3>
        {%- else -%}
          <p
            class="marquee-section__heading {{ section.settings.heading_size }}{% if section.settings.heading_underline %} marquee-section__heading--underline{% endif %}"
            style="color:{{ section.settings.heading_color }};font-weight:{{ section.settings.heading_weight }};"
          >{{ section.settings.heading | escape }}</p>
      {%- endcase -%}
    </div>
  {%- endif -%}

  <marquee-ticker
    data-direction="{{ section.settings.direction }}"
    data-pause-hover="{{ section.settings.pause_on_hover }}"
  >
    <div class="marquee-track">
      <div class="marquee-inner" data-marquee-inner>

        {%- for block in section.blocks -%}
          {%- case block.type -%}

            {%- when 'text' -%}
              <span
                class="marquee-item marquee-item--text {{ block.settings.font_size }}"
                style="color:{{ block.settings.text_color }};font-weight:{{ block.settings.font_weight }};"
                {{ block.shopify_attributes }}
              >
                {{- block.settings.text | escape -}}
              </span>

            {%- when 'image' -%}
              <div
                class="marquee-item marquee-item--image"
                style="width:{{ block.settings.image_width }}px;"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.image != blank -%}
                  {%- assign img_sizes = block.settings.image_width | append: 'px' -%}
                  {{
                    block.settings.image
                    | image_url: width: 600
                    | image_tag:
                      loading: 'lazy',
                      widths: '100, 150, 200, 300, 400, 600',
                      sizes: img_sizes
                  }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>

            {%- when 'separator' -%}
              <span
                class="marquee-item marquee-item--separator {{ block.settings.font_size }}"
                style="color:{{ block.settings.color }};"
                aria-hidden="true"
                {{ block.shopify_attributes }}
              >
                {{- block.settings.character | escape -}}
              </span>

          {%- endcase -%}
        {%- endfor -%}

      </div>
    </div>
  </marquee-ticker>

  {%- if section.settings.show_border_bottom -%}
    <div class="marquee-section__border"></div>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "Marquee",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading text",
      "default": "Available Nationwide At:"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading HTML tag",
      "info": "Choose based on page hierarchy (h2 recommended)",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "p",  "label": "Paragraph" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "mq-heading--xs", "label": "Extra small" },
        { "value": "mq-heading--sm", "label": "Small"       },
        { "value": "mq-heading--md", "label": "Medium"      },
        { "value": "mq-heading--lg", "label": "Large"       },
        { "value": "mq-heading--xl", "label": "Extra large" }
      ],
      "default": "mq-heading--sm"
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "options": [
        { "value": "400", "label": "Regular"   },
        { "value": "500", "label": "Medium"    },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold"      },
        { "value": "800", "label": "Black"     }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left",   "label": "Left"   },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right"  }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "heading_underline",
      "label": "Show underline",
      "default": true
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "heading_gap",
      "label": "Space below heading",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Speed",
      "info": "Duration in seconds — lower = faster",
      "min": 5,
      "max": 120,
      "step": 5,
      "unit": "s",
      "default": 30
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Scroll direction",
      "options": [
        { "value": "left",  "label": "Left (default)" },
        { "value": "right", "label": "Right"          }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_edge_fade",
      "label": "Fade edges",
      "info": "Soft fade at left and right edges",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "item_gap",
      "label": "Gap between items",
      "min": 8,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "‰",
      "info": "Value ÷ 100 = em (e.g. 2 → 0.02em)",
      "default": 2
    },
    {
      "type": "header",
      "content": "Image height"
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Desktop image height",
      "min": 20,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 44
    },
    {
      "type": "range",
      "id": "image_height_mobile",
      "label": "Mobile image height",
      "min": 16,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 28
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Desktop padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Desktop padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile padding top",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile padding bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#D6EAF8"
    },
    {
      "type": "header",
      "content": "Borders"
    },
    {
      "type": "checkbox",
      "id": "show_border_top",
      "label": "Show top border",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_border_bottom",
      "label": "Show bottom border",
      "default": false
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#B0C4DE"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border thickness",
      "min": 1,
      "max": 6,
      "step": 1,
      "unit": "px",
      "default": 1
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free Shipping Worldwide"
        },
        {
          "type": "select",
          "id": "font_size",
          "label": "Font size",
          "options": [
            { "value": "font-size-12-14", "label": "Extra small" },
            { "value": "font-size-14-16", "label": "Small"       },
            { "value": "font-size-16-18", "label": "Medium"      },
            { "value": "font-size-18-20", "label": "Large"       },
            { "value": "font-size-20-24", "label": "Extra large" },
            { "value": "font-size-24-32", "label": "Display"     },
            { "value": "font-size-32-48", "label": "Headline"    }
          ],
          "default": "font-size-16-18"
        },
        {
          "type": "select",
          "id": "font_weight",
          "label": "Font weight",
          "options": [
            { "value": "400", "label": "Regular"    },
            { "value": "500", "label": "Medium"     },
            { "value": "600", "label": "Semi-bold"  },
            { "value": "700", "label": "Bold"       },
            { "value": "800", "label": "Extra bold" },
            { "value": "900", "label": "Black"      }
          ],
          "default": "500"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#111111"
        }
      ]
    },
    {
      "type": "image",
      "name": "Image item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "range",
          "id": "image_width",
          "label": "Image width",
          "info": "Height is set by the section-level image height",
          "min": 24,
          "max": 300,
          "step": 4,
          "unit": "px",
          "default": 120
        }
      ]
    },
    {
      "type": "separator",
      "name": "Separator",
      "settings": [
        {
          "type": "text",
          "id": "character",
          "label": "Separator character",
          "info": "e.g. · ★ / — ✦ ❖ •",
          "default": "·"
        },
        {
          "type": "select",
          "id": "font_size",
          "label": "Size",
          "options": [
            { "value": "font-size-12-14", "label": "Extra small" },
            { "value": "font-size-14-16", "label": "Small"       },
            { "value": "font-size-16-18", "label": "Medium"      },
            { "value": "font-size-18-20", "label": "Large"       },
            { "value": "font-size-20-24", "label": "Extra large" },
            { "value": "font-size-24-32", "label": "Display"     }
          ],
          "default": "font-size-18-20"
        },
        {
          "type": "color",
          "id": "color",
          "label": "Color",
          "default": "#888888"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
