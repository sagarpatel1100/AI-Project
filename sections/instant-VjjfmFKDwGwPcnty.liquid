          <script>
            const scriptURL = 'TU_URL_DE_APPSCRIPT'; // pon aquí la URL de tu Apps Script
            const form = document.getElementById('webinarForm');
            const formMessage = document.getElementById('formMessage');
            const countrySelect = document.getElementById('pais');

            form.addEventListener('submit', (e) => {
              e.preventDefault();
              showMessage('Sending registration... ⏳', 'loading');
              fetch('https://script.google.com/macros/s/AKfycbz9oXhT8oFFMe4kNLdaQsOBaSBsCjM368jEIW8zw5CNY1-cbQxuSnQHSWLOPnnWtDAEBw/exec', {
                method: 'POST',
                body: new FormData(form),
              })
                .then((response) => {
                  if (response.ok) {
                    showMessage('Registration sent successfully ✅', 'success');
                    form.reset();
                  } else {
                    showMessage('There was a problem sending the registration, please try again ❌', 'error');
                  }
                })
                .catch(() => showMessage('Connection error, please try again ❌', 'error'));
            });

            function showMessage(message, type) {
              formMessage.textContent = message;
              formMessage.classList.remove('success', 'error', 'loading');
              formMessage.classList.add(type);
              formMessage.style.display = 'block';

              if (type !== 'loading') {
                setTimeout(() => {
                  formMessage.style.display = 'none';
                  formMessage.textContent = '';
                  formMessage.classList.remove('success', 'error', 'loading');
                }, 15000);
              }
            }
