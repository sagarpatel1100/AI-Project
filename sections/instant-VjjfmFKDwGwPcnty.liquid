      <script>
        document.addEventListener('DOMContentLoaded', () => {
          const el = document.querySelector('.units-left-number');

          const STARTING_UNITS = 2000;
          const FAST_PHASE_SECONDS = 3600;
          const FAST_RATE = 5;
          const SLOW_RATE = 60;
          const MIN_UNITS = 20;

          function calculateUnits() {
            const now = new Date();

            const startOfDayUTC = Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate(), 0, 0, 0);

            const nowUTC = now.getTime();
            const secondsPassed = Math.floor((nowUTC - startOfDayUTC) / 1000);

            let unitsLeft;

            if (secondsPassed <= FAST_PHASE_SECONDS) {
              const unitsLostFast = Math.floor(secondsPassed / FAST_RATE);
              unitsLeft = STARTING_UNITS - unitsLostFast;
            } else {
              const unitsLostFast = Math.floor(FAST_PHASE_SECONDS / FAST_RATE);
              const remainingSeconds = secondsPassed - FAST_PHASE_SECONDS;
              const unitsLostSlow = Math.floor(remainingSeconds / SLOW_RATE);

              unitsLeft = STARTING_UNITS - unitsLostFast - unitsLostSlow;
            }

            return Math.max(unitsLeft, MIN_UNITS);
          }

          function updateUnits() {
            const newUnits = calculateUnits();
            const currentUnits = parseInt(el.textContent);

            if (newUnits !== currentUnits) {
              // ⚡ Animación cuando cambia
              el.classList.add('changing');

              setTimeout(() => {
                el.textContent = newUnits;
                el.classList.remove('changing');
              }, 200); // un poco antes del 0.4s para hacer el flip natural
            }
          }

          updateUnits();
          setInterval(updateUnits, 5000);
        });
      </script>

      <style>
        .units-left-number {
          display: inline-block !important;
          transition:
            transform 0.4s ease,
            opacity 0.4s ease !important;
        }

        .units-left-number.changing {
          transform: scale(1.25) !important;
          opacity: 0.4 !important;
        }
      </style>
