      "step": 4,
      "default": 388
    },
    {
      "type": "range",
      "id": "desktop_content_padding_right",
      "label": "Desktop content right padding",
      "min": 0,
      "max": 300,
      "step": 4,
      "default": 148
    },
    {
      "type": "range",
      "id": "desktop_content_padding_left",
      "label": "Desktop content left padding",
      "min": 0,
      "max": 300,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "mobile_content_padding_top",
      "label": "Mobile content top padding",
