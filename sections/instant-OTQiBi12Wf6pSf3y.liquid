    {
      "type": "richtext",
      "id": "text_3HQ9ZtXP9l7ntAFc",
      "label": "Heading 1 → Vitals⁺ & Biotic⁺ bundle",
      "default": "<p>BIG TRUCK TEST</p>"
    },
    {
      "type": "richtext",
      "id": "text_H60VMMoaLOFpCeUK",
      "label": "Text",
      "default": "<p>The Blaze survived under a truck, thanks to its zinc alloy body and Gorilla Glass—no scratches, no problem.</p>"
    },
    {
      "type": "video",
      "id": "video_Rb0Xxep9B7fzDdnE",
