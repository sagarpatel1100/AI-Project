    {
      "type": "richtext",
      "id": "text_r7SODBN7EDGlhdmH",
      "label": "Heading 1 → Vitals⁺ & Biotic⁺ bundle",
      "default": "<p>WATER TEST</p>"
    },
    {
      "type": "richtext",
      "id": "text_rQI7jxBBCQauiEk4",
      "label": "Text",
      "default": "<p>With IP69K water resistance, the Blaze handles water like a pro—swim, shower, or rain, it keeps going strong.</p>"
    },
    {
      "type": "video",
      "id": "video_guEycKHlRfkimiOD",
