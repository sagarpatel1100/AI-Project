    {
      "type": "richtext",
      "id": "text_eJpmHqD8IGsL1ANd",
      "label": "Text",
      "default": "<p>\"The Blaze is hands-down my favorite. I&apos;m glad I skipped the overpriced name brands. This thing gives you 10X the value for a fraction of the cost. Built tough, works like a charm, and doesn&apos;t break the bank.\"</p>"
