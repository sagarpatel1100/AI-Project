{{ 'section-split-media.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #SplitMedia-{{ section.id }} {
    --sm-bg:                     {{ section.settings.bg_color }};
    --sm-height:                 {{ section.settings.section_height }};
    --sm-mobile-height:          {{ section.settings.mobile_height }};
    --sm-gap:                    {{ section.settings.column_gap }}px;
    --sm-mobile-gap:             {{ section.settings.mobile_column_gap }}px;
    --sm-radius:                 {{ section.settings.border_radius }}px;
    --sm-padding-top:            {{ section.settings.padding_top }}px;
    --sm-padding-bottom:         {{ section.settings.padding_bottom }}px;
    --sm-mobile-padding-top:     {{ section.settings.mobile_padding_top }}px;
    --sm-mobile-padding-bottom:  {{ section.settings.mobile_padding_bottom }}px;
    --sm-content-padding:        {{ section.settings.content_padding }}px;
    --sm-content-padding-mobile: {{ section.settings.content_padding_mobile }}px;
    --sm-outer-h-pad:            {{ section.settings.outer_horizontal_padding }}px;
  }
{%- endstyle -%}

<div
  id="SplitMedia-{{ section.id }}"
  class="sm-section{% if section.settings.mobile_reverse %} sm-section--mobile-reverse{% endif %}"
>
  <div class="sm-section__inner">
    <div class="sm-grid">

      {%- for block in section.blocks -%}
        {%- assign pos_parts = block.settings.content_position | split: '-' -%}
        {%- assign v_pos = pos_parts[0] -%}
        {%- assign h_pos = pos_parts[1] -%}

        <div
          class="sm-col"
          {{ block.shopify_attributes }}
        >

          {%- comment -%} ── Media ── {%- endcomment -%}
          <div class="sm-media">
            {%- if block.settings.media_type == 'video' -%}
              {%- if block.settings.video_url != blank -%}
                {%- if block.settings.video_url.type == 'youtube' -%}
                  <iframe
                    src="https://www.youtube.com/embed/{{ block.settings.video_url.id }}?autoplay=1&mute=1&loop=1&playlist={{ block.settings.video_url.id }}&controls=0&rel=0&playsinline=1&modestbranding=1"
                    allow="autoplay; encrypted-media"
                    allowfullscreen
                    loading="lazy"
                    title="{{ block.settings.heading | default: 'Video' | escape }}"
                  ></iframe>
                {%- elsif block.settings.video_url.type == 'vimeo' -%}
                  <iframe
                    src="https://player.vimeo.com/video/{{ block.settings.video_url.id }}?autoplay=1&muted=1&loop=1&background=1&autopause=0"
                    allow="autoplay; fullscreen; picture-in-picture"
                    allowfullscreen
                    loading="lazy"
                    title="{{ block.settings.heading | default: 'Video' | escape }}"
                  ></iframe>
                {%- endif -%}
              {%- else -%}
                {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            {%- else -%}
              {%- if block.settings.image != blank -%}
                {%- assign img_sizes = '(min-width: 750px) 50vw, 100vw' -%}
                {{
                  block.settings.image
                  | image_url: width: 1400
                  | image_tag:
                    widths: '400, 600, 800, 1000, 1200, 1400',
                    sizes: img_sizes,
                    loading: 'lazy'
                }}
              {%- else -%}
                {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            {%- endif -%}
          </div>

          {%- comment -%} ── Scrim / overlay ── {%- endcomment -%}
          <div
            class="sm-scrim sm-scrim--{{ block.settings.overlay_style }}"
            style="--scrim-opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};"
          ></div>

          {%- comment -%} ── Corner badge (e.g. ENDS / 10/01) ── {%- endcomment -%}
          {%- if block.settings.corner_badge_value != blank -%}
            <div
              class="sm-corner-badge"
              style="--corner-badge-bg: {{ block.settings.corner_badge_bg }}; --corner-badge-color: {{ block.settings.corner_badge_color }};"
            >
              {%- if block.settings.corner_badge_label != blank -%}
                <span class="sm-corner-badge__label">{{ block.settings.corner_badge_label | escape }}</span>
              {%- endif -%}
              <span class="sm-corner-badge__value">{{ block.settings.corner_badge_value | escape }}</span>
            </div>
          {%- endif -%}

          {%- comment -%} ── Content overlay ── {%- endcomment -%}
          <div class="sm-content sm-content--{{ v_pos }} sm-content--{{ h_pos }}">

            {%- if block.settings.inline_badge != blank -%}
              <span
                class="sm-inline-badge"
                style="background-color: {{ block.settings.inline_badge_bg }}; color: {{ block.settings.inline_badge_color }};"
              >
                {{- block.settings.inline_badge | escape -}}
              </span>
            {%- endif -%}

            {%- if block.settings.heading != blank -%}
              <h2
                class="sm-heading sm-heading--{{ block.settings.heading_size }} {{ block.settings.heading_font_size }}"
                style="color: {{ block.settings.text_color }};"
              >
                {{ block.settings.heading }}
              </h2>
            {%- endif -%}

            {%- if block.settings.description != blank -%}
              <div
                class="sm-description rte {{ block.settings.desc_font_size }}"
                style="color: {{ block.settings.text_color }};"
              >
                {{ block.settings.description }}
              </div>
            {%- endif -%}

            {%- if block.settings.button_label != blank -%}
              <div class="sm-btn-wrap">
                <a
                  {% if block.settings.button_link != blank %}
                    href="{{ block.settings.button_link }}"
                  {% else %}
                    role="link" aria-disabled="true"
                  {% endif %}
                  class="{% if block.settings.button_style == 'secondary' %}n-button-secondary{% else %}n-button-primary{% endif %}"
                  style="--sm-btn-bg: {{ block.settings.button_bg_color }}; --sm-btn-text: {{ block.settings.button_text_color }}; --sm-btn2-bg: {{ block.settings.button_secondary_bg_color }}; --sm-btn2-text: {{ block.settings.button_text_color }};"
                >
                  {{- block.settings.button_label | escape -}}
                </a>
              </div>
            {%- endif -%}

          </div>

        </div>
      {%- endfor -%}

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Split media",
  "tag": "section",
  "class": "section",
  "max_blocks": 2,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Height"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Desktop panel height",
      "options": [
        { "value": "36rem",  "label": "Small"       },
        { "value": "48rem",  "label": "Medium"      },
        { "value": "60rem",  "label": "Large"       },
        { "value": "72rem",  "label": "Extra large" },
        { "value": "100vh",  "label": "Full screen" }
      ],
      "default": "48rem"
    },
    {
      "type": "select",
      "id": "mobile_height",
      "label": "Mobile panel height",
      "options": [
        { "value": "30rem",  "label": "Small"       },
        { "value": "40rem",  "label": "Medium"      },
        { "value": "52rem",  "label": "Large"       },
        { "value": "65rem",  "label": "Extra large" },
        { "value": "100vh",  "label": "Full screen" }
      ],
      "default": "40rem"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Panel corner radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Gap between panels",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "mobile_column_gap",
      "label": "Mobile gap between panels",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "mobile_reverse",
      "label": "Reverse order on mobile",
      "info": "Show second panel above first on mobile",
      "default": false
    },
    {
      "type": "header",
      "content": "Content padding"
    },
    {
      "type": "range",
      "id": "content_padding",
      "label": "Desktop inner padding",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "content_padding_mobile",
      "label": "Mobile inner padding",
      "min": 12,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "outer_horizontal_padding",
      "label": "Outer horizontal padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile padding top",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile padding bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#F2F4F7"
    }
  ],
  "blocks": [
    {
      "type": "panel",
      "name": "Panel",
      "settings": [
        {
          "type": "header",
          "content": "Media"
        },
        {
          "type": "select",
          "id": "media_type",
          "label": "Media type",
          "options": [
            { "value": "image", "label": "Image"                  },
            { "value": "video", "label": "Video (YouTube / Vimeo)" }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Used when Media type is Image"
        },
        {
          "type": "video_url",
          "id": "video_url",
          "label": "Video URL",
          "info": "YouTube or Vimeo. Used when Media type is Video.",
          "accept": ["youtube", "vimeo"]
        },
        {
          "type": "header",
          "content": "Overlay"
        },
        {
          "type": "select",
          "id": "overlay_style",
          "label": "Overlay style",
          "options": [
            { "value": "gradient", "label": "Gradient (dark at bottom)" },
            { "value": "flat",     "label": "Flat (uniform)"            }
          ],
          "default": "gradient"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Overlay strength",
          "min": 0,
          "max": 95,
          "step": 5,
          "unit": "%",
          "default": 55
        },
        {
          "type": "header",
          "content": "Corner badge"
        },
        {
          "type": "text",
          "id": "corner_badge_label",
          "label": "Label (small text)",
          "info": "e.g. ENDS",
          "default": "ENDS"
        },
        {
          "type": "text",
          "id": "corner_badge_value",
          "label": "Value (large text)",
          "info": "e.g. 10/01 — leave blank to hide badge"
        },
        {
          "type": "color",
          "id": "corner_badge_bg",
          "label": "Badge background",
          "default": "#0D3B6E"
        },
        {
          "type": "color",
          "id": "corner_badge_color",
          "label": "Badge text color",
          "default": "#FFFFFF"
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "select",
          "id": "content_position",
          "label": "Content position",
          "options": [
            { "value": "top-left",      "label": "Top left"      },
            { "value": "top-center",    "label": "Top center"    },
            { "value": "top-right",     "label": "Top right"     },
            { "value": "middle-left",   "label": "Middle left"   },
            { "value": "middle-center", "label": "Middle center" },
            { "value": "middle-right",  "label": "Middle right"  },
            { "value": "bottom-left",   "label": "Bottom left"   },
            { "value": "bottom-center", "label": "Bottom center" },
            { "value": "bottom-right",  "label": "Bottom right"  }
          ],
          "default": "bottom-left"
        },
        {
          "type": "text",
          "id": "inline_badge",
          "label": "Inline badge text",
          "info": "e.g. TODAY ONLY! — leave blank to hide"
        },
        {
          "type": "color",
          "id": "inline_badge_bg",
          "label": "Inline badge background",
          "default": "#F5C800"
        },
        {
          "type": "color",
          "id": "inline_badge_color",
          "label": "Inline badge text color",
          "default": "#000000"
        },
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading",
          "default": "Panel Heading"
        },
        {
          "type": "select",
          "id": "heading_size",
          "label": "Heading size",
          "options": [
            { "value": "sm",  "label": "Small"       },
            { "value": "md",  "label": "Medium"      },
            { "value": "lg",  "label": "Large"       },
            { "value": "xl",  "label": "Extra large" },
            { "value": "xxl", "label": "XX large"    }
          ],
          "default": "lg"
        },
        {
          "type": "select",
          "id": "heading_font_size",
          "label": "Heading font size (fine-tune)",
          "options": [
            { "value": "",              "label": "Default (from size)"  },
            { "value": "font-size-18-20", "label": "18–20px"           },
            { "value": "font-size-20-24", "label": "20–24px"           },
            { "value": "font-size-24-30", "label": "24–30px"           },
            { "value": "font-size-28-36", "label": "28–36px"           },
            { "value": "font-size-36-48", "label": "36–48px"           }
          ],
          "default": ""
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "select",
          "id": "desc_font_size",
          "label": "Description font size",
          "options": [
            { "value": "font-size-12-14", "label": "12–14px" },
            { "value": "font-size-13-15", "label": "13–15px" },
            { "value": "font-size-14-16", "label": "14–16px" },
            { "value": "font-size-16-18", "label": "16–18px" }
          ],
          "default": "font-size-14-16"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#FFFFFF"
        },
        {
          "type": "header",
          "content": "Button"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button style",
          "options": [
            { "value": "primary",   "label": "Primary (filled)"   },
            { "value": "secondary", "label": "Secondary (outline)" }
          ],
          "default": "primary"
        },
        {
          "type": "color",
          "id": "button_bg_color",
          "label": "Primary button background",
          "default": "#1565C0"
        },
        {
          "type": "color",
          "id": "button_text_color",
          "label": "Button text color",
          "default": "#FFFFFF"
        },
        {
          "type": "color",
          "id": "button_secondary_bg_color",
          "label": "Secondary button background",
          "info": "Applies to Secondary style only",
          "default": "#FFFFFF"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Split media",
      "blocks": [
        {
          "type": "panel",
          "settings": {
            "heading": "15% OFF For Senior's Day",
            "inline_badge": "TODAY ONLY!",
            "corner_badge_label": "ENDS",
            "corner_badge_value": "10/01",
            "description": "Free Shipping Included! Celebrate with 15% OFF sitewide.",
            "button_label": "Shop Now",
            "button_style": "primary",
            "content_position": "bottom-left",
            "overlay_style": "gradient"
          }
        },
        {
          "type": "panel",
          "settings": {
            "heading": "Need Help Finding The Right Solution?",
            "description": "Take the quiz and discover the product that's best suited to your unique needs.",
            "button_label": "Take Pain Quiz",
            "button_style": "secondary",
            "content_position": "bottom-left",
            "overlay_style": "flat"
          }
        }
      ]
    }
  ]
}
{% endschema %}
