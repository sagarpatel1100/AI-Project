{{ 'section-split-media.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #SplitMedia-{{ section.id }} {
    --sm-height:                 {{ section.settings.section_height }};
    --sm-mobile-height:          {{ section.settings.mobile_height }};
    --sm-gap:                    {{ section.settings.column_gap }}px;
    --sm-mobile-gap:             {{ section.settings.mobile_column_gap }}px;
    --sm-bg:                     {{ section.settings.bg_color }};
    --sm-padding-top:            {{ section.settings.padding_top }}px;
    --sm-padding-bottom:         {{ section.settings.padding_bottom }}px;
    --sm-mobile-padding-top:     {{ section.settings.mobile_padding_top }}px;
    --sm-mobile-padding-bottom:  {{ section.settings.mobile_padding_bottom }}px;
    --sm-content-padding:        {{ section.settings.content_padding }}px;
    --sm-content-padding-mobile: {{ section.settings.content_padding_mobile }}px;
  }
{%- endstyle -%}

<div
  id="SplitMedia-{{ section.id }}"
  class="sm-section{% if section.settings.mobile_reverse %} sm-section--mobile-reverse{% endif %}"
>
  <div class="sm-grid">

    {%- for block in section.blocks -%}
      {%- assign v_pos = block.settings.content_position | split: '-' | first -%}
      {%- assign h_pos = block.settings.content_position | split: '-' | last  -%}

      <div
        class="sm-col"
        {{ block.shopify_attributes }}
      >

        {{- '<!-- Media layer -->' -}}
        <div class="sm-media">
          {%- if block.settings.media_type == 'video' -%}
            {%- if block.settings.video_url != blank -%}
              {%- if block.settings.video_url.type == 'youtube' -%}
                <iframe
                  src="https://www.youtube.com/embed/{{ block.settings.video_url.id }}?autoplay=1&mute=1&loop=1&playlist={{ block.settings.video_url.id }}&controls=0&rel=0&showinfo=0&playsinline=1&modestbranding=1"
                  allow="autoplay; encrypted-media"
                  allowfullscreen
                  loading="lazy"
                  title="{{ block.settings.heading | default: 'Video' | escape }}"
                ></iframe>
              {%- elsif block.settings.video_url.type == 'vimeo' -%}
                <iframe
                  src="https://player.vimeo.com/video/{{ block.settings.video_url.id }}?autoplay=1&muted=1&loop=1&background=1&autopause=0"
                  allow="autoplay; fullscreen; picture-in-picture"
                  allowfullscreen
                  loading="lazy"
                  title="{{ block.settings.heading | default: 'Video' | escape }}"
                ></iframe>
              {%- endif -%}
            {%- else -%}
              {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          {%- else -%}
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 1400
                | image_tag:
                  widths: '400, 600, 800, 1000, 1200, 1400',
                  sizes: '(min-width: 750px) 50vw, 100vw',
                  loading: 'lazy'
              }}
            {%- else -%}
              {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          {%- endif -%}
        </div>

        {{- '<!-- Dark scrim -->' -}}
        <div
          class="sm-scrim"
          style="--scrim-opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};"
        ></div>

        {{- '<!-- Text content -->' -}}
        <div class="sm-content sm-content--{{ v_pos }} sm-content--{{ h_pos }}">

          {%- if block.settings.subheading != blank -%}
            <p
              class="sm-subheading"
              style="color: {{ block.settings.text_color }};"
            >
              {{ block.settings.subheading | escape }}
            </p>
          {%- endif -%}

          {%- if block.settings.heading != blank -%}
            <h2
              class="sm-heading sm-heading--{{ block.settings.heading_size }}"
              style="color: {{ block.settings.text_color }};"
            >
              {{ block.settings.heading }}
            </h2>
          {%- endif -%}

          {%- if block.settings.description != blank -%}
            <p
              class="sm-description"
              style="color: {{ block.settings.text_color }};"
            >
              {{ block.settings.description | escape }}
            </p>
          {%- endif -%}

          {%- if block.settings.button_label != blank -%}
            <a
              {% if block.settings.button_link != blank %}
                href="{{ block.settings.button_link }}"
              {% else %}
                role="link" aria-disabled="true"
              {% endif %}
              class="button{% if block.settings.button_style == 'secondary' %} button--secondary{% else %} button--primary{% endif %}"
            >
              {{- block.settings.button_label | escape -}}
            </a>
          {%- endif -%}

        </div>

      </div>
    {%- endfor -%}

  </div>
</div>

{% schema %}
{
  "name": "Split media",
  "tag": "section",
  "class": "section",
  "max_blocks": 2,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Height"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Desktop height",
      "options": [
        { "value": "35vh",  "label": "Small"       },
        { "value": "55vh",  "label": "Medium"      },
        { "value": "70vh",  "label": "Large"       },
        { "value": "85vh",  "label": "Extra large" },
        { "value": "100vh", "label": "Full screen" }
      ],
      "default": "55vh"
    },
    {
      "type": "select",
      "id": "mobile_height",
      "label": "Mobile height (per panel)",
      "options": [
        { "value": "30vh", "label": "Small"       },
        { "value": "45vh", "label": "Medium"      },
        { "value": "60vh", "label": "Large"       },
        { "value": "75vh", "label": "Extra large" },
        { "value": "100vh","label": "Full screen" }
      ],
      "default": "45vh"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Desktop gap between panels",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "mobile_column_gap",
      "label": "Mobile gap between panels",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "mobile_reverse",
      "label": "Reverse order on mobile",
      "info": "Show second panel above first on mobile",
      "default": false
    },
    {
      "type": "header",
      "content": "Content padding"
    },
    {
      "type": "range",
      "id": "content_padding",
      "label": "Desktop inner padding",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "content_padding_mobile",
      "label": "Mobile inner padding",
      "min": 12,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile padding top",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile padding bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#000000"
    }
  ],
  "blocks": [
    {
      "type": "panel",
      "name": "Panel",
      "settings": [
        {
          "type": "header",
          "content": "Media"
        },
        {
          "type": "select",
          "id": "media_type",
          "label": "Media type",
          "options": [
            { "value": "image", "label": "Image"                 },
            { "value": "video", "label": "Video (YouTube/Vimeo)" }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Used when media type is set to Image"
        },
        {
          "type": "video_url",
          "id": "video_url",
          "label": "Video URL",
          "info": "YouTube or Vimeo URL. Used when media type is set to Video.",
          "accept": ["youtube", "vimeo"]
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Dark overlay opacity",
          "info": "Darkens media to improve text legibility",
          "min": 0,
          "max": 90,
          "step": 5,
          "unit": "%",
          "default": 35
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "info": "Small label above the heading"
        },
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading",
          "default": "Panel heading"
        },
        {
          "type": "select",
          "id": "heading_size",
          "label": "Heading size",
          "options": [
            { "value": "sm",  "label": "Small"       },
            { "value": "md",  "label": "Medium"      },
            { "value": "lg",  "label": "Large"       },
            { "value": "xl",  "label": "Extra large" },
            { "value": "xxl", "label": "XX large"    }
          ],
          "default": "lg"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "header",
          "content": "Button"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button style",
          "options": [
            { "value": "primary",   "label": "Primary (filled)"  },
            { "value": "secondary", "label": "Secondary (outline)" }
          ],
          "default": "primary"
        },
        {
          "type": "header",
          "content": "Text style"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#FFFFFF"
        },
        {
          "type": "select",
          "id": "content_position",
          "label": "Content position",
          "options": [
            { "value": "top-left",     "label": "Top left"      },
            { "value": "top-center",   "label": "Top center"    },
            { "value": "top-right",    "label": "Top right"     },
            { "value": "middle-left",  "label": "Middle left"   },
            { "value": "middle-center","label": "Middle center" },
            { "value": "middle-right", "label": "Middle right"  },
            { "value": "bottom-left",  "label": "Bottom left"   },
            { "value": "bottom-center","label": "Bottom center" },
            { "value": "bottom-right", "label": "Bottom right"  }
          ],
          "default": "bottom-left"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Split media",
      "blocks": [
        {
          "type": "panel",
          "settings": {
            "heading": "First Panel",
            "content_position": "bottom-left"
          }
        },
        {
          "type": "panel",
          "settings": {
            "heading": "Second Panel",
            "content_position": "bottom-left"
          }
        }
      ]
    }
  ]
}
{% endschema %}
