{{ 'section-trade-in-watch-worth.css' | asset_url | stylesheet_tag }}

<section
  id="trade-in-watch-worth-{{ section.id }}"
  class="trade-in-watch-worth"
  style="
    --trade-in-watch-worth-bg: {{ section_bg_color }};
    --trade-in-watch-worth-heading-color: {{ heading_color }};
    --trade-in-watch-worth-highlight-color: {{ highlight_color }};
    --trade-in-watch-worth-description-color: {{ description_color }};
    --trade-in-watch-worth-cards-bg-start: {{ cards_wrapper_bg_start }};
    --trade-in-watch-worth-cards-bg-end: {{ cards_wrapper_bg_end }};

    --trade-in-watch-worth-content-max-width: {{ content_max_width }}px;

    --trade-in-watch-worth-padding-top: {{ section_padding_top }}px;
    --trade-in-watch-worth-padding-bottom: {{ section_padding_bottom }}px;
    --trade-in-watch-worth-padding-horizontal: {{ section_padding_horizontal }}px;

    --trade-in-watch-worth-padding-top-mobile: {{ section_padding_top_mobile }}px;
    --trade-in-watch-worth-padding-bottom-mobile: {{ section_padding_bottom_mobile }}px;
    --trade-in-watch-worth-padding-horizontal-mobile: {{ section_padding_horizontal_mobile }}px;

    --trade-in-watch-worth-heading-size-desktop: {{ heading_size_desktop }}px;
    --trade-in-watch-worth-heading-size-mobile: {{ heading_size_mobile }}px;
    --trade-in-watch-worth-description-size-desktop: {{ description_size_desktop }}px;
    --trade-in-watch-worth-description-size-mobile: {{ description_size_mobile }}px;

    --trade-in-watch-worth-heading-gap-desktop: {{ heading_gap_desktop }}px;
    --trade-in-watch-worth-heading-gap-mobile: {{ heading_gap_mobile }}px;
    --trade-in-watch-worth-cards-gap-desktop: {{ cards_gap_desktop }}px;
    --trade-in-watch-worth-cards-gap-mobile: {{ cards_gap_mobile }}px;

    --trade-in-watch-worth-card-width-desktop: {{ card_width_desktop }}px;
    --trade-in-watch-worth-card-width-mobile: {{ card_width_mobile }}px;
    --trade-in-watch-worth-card-radius: {{ card_radius }}px;

    --trade-in-watch-worth-card-padding-top: {{ card_padding_top }}px;
    --trade-in-watch-worth-card-padding-right: {{ card_padding_right }}px;
    --trade-in-watch-worth-card-padding-bottom: {{ card_padding_bottom }}px;
    --trade-in-watch-worth-card-padding-left: {{ card_padding_left }}px;

    --trade-in-watch-worth-card-padding-top-mobile: {{ card_padding_top_mobile }}px;
    --trade-in-watch-worth-card-padding-right-mobile: {{ card_padding_right_mobile }}px;
    --trade-in-watch-worth-card-padding-bottom-mobile: {{ card_padding_bottom_mobile }}px;
    --trade-in-watch-worth-card-padding-left-mobile: {{ card_padding_left_mobile }}px;

    --trade-in-watch-worth-image-width-desktop: {{ image_width_desktop }}px;
    --trade-in-watch-worth-image-height-desktop: {{ image_height_desktop }}px;
    --trade-in-watch-worth-image-width-mobile: {{ image_width_mobile }}px;
    --trade-in-watch-worth-image-height-mobile: {{ image_height_mobile }}px;

    --trade-in-watch-worth-title-size-desktop: {{ title_size_desktop }}px;
    --trade-in-watch-worth-title-size-mobile: {{ title_size_mobile }}px;
    --trade-in-watch-worth-price-size-desktop: {{ price_size_desktop }}px;
    --trade-in-watch-worth-price-size-mobile: {{ price_size_mobile }}px;
    --trade-in-watch-worth-suffix-size-desktop: {{ suffix_size_desktop }}px;
    --trade-in-watch-worth-suffix-size-mobile: {{ suffix_size_mobile }}px;
    --trade-in-watch-worth-card-description-size-desktop: {{ card_description_size_desktop }}px;
    --trade-in-watch-worth-card-description-size-mobile: {{ card_description_size_mobile }}px;

    --trade-in-watch-worth-badge-font-size: {{ badge_font_size }}px;
    --trade-in-watch-worth-badge-font-size-mobile: {{ badge_font_size_mobile }}px;
    --trade-in-watch-worth-badge-padding-vertical: {{ badge_padding_vertical }}px;
    --trade-in-watch-worth-badge-padding-horizontal: {{ badge_padding_horizontal }}px;
    --trade-in-watch-worth-badge-rotation: {{ badge_rotation }}deg;
  "
>
  <div class="trade-in-watch-worth__inner">
    <div class="trade-in-watch-worth__container">
      {% if has_intro %}
        <div class="trade-in-watch-worth__intro">
          {% if heading_line_1 != blank or heading_highlight != blank %}
            <h2 class="trade-in-watch-worth__heading">
              {% if heading_line_1 != blank %}
                <span class="trade-in-watch-worth__heading-text">{{ heading_line_1 }}</span>
              {% endif %}
              {% if heading_highlight != blank %}
                <span class="trade-in-watch-worth__heading-text trade-in-watch-worth__heading-text--highlight">{{ heading_highlight }}</span>
              {% endif %}
            </h2>
          {% endif %}

          {% if description != blank %}
            <div class="trade-in-watch-worth__description rte">
              {{ description }}
            </div>
          {% endif %}
        </div>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <div class="trade-in-watch-worth__cards">
          {% for block in section.blocks %}
            {% liquid
              assign card_image = block.settings.card_image
              assign card_title = block.settings.card_title
              assign card_price = block.settings.card_price
              assign card_suffix = block.settings.card_suffix
              assign card_description = block.settings.card_description
              assign featured_badge_text = block.settings.featured_badge_text
              assign enable_featured = block.settings.enable_featured

              assign card_bg_color = block.settings.card_bg_color
              assign card_border_color = block.settings.card_border_color
              assign featured_border_color = block.settings.featured_border_color
              assign title_color = block.settings.title_color
              assign price_color = block.settings.price_color
              assign suffix_color = block.settings.suffix_color
              assign card_description_color = block.settings.card_description_color
              assign badge_bg_color = block.settings.badge_bg_color
              assign badge_text_color = block.settings.badge_text_color
            %}

            <div
              class="trade-in-watch-worth__card{% if enable_featured %} trade-in-watch-worth__card--featured{% endif %}"
              style="
                --trade-in-watch-worth-card-bg: {{ card_bg_color }};
                --trade-in-watch-worth-card-border: {{ card_border_color }};
                --trade-in-watch-worth-card-featured-border: {{ featured_border_color }};
                --trade-in-watch-worth-card-title-color: {{ title_color }};
                --trade-in-watch-worth-card-price-color: {{ price_color }};
                --trade-in-watch-worth-card-suffix-color: {{ suffix_color }};
                --trade-in-watch-worth-card-description-color: {{ card_description_color }};
                --trade-in-watch-worth-badge-bg: {{ badge_bg_color }};
                --trade-in-watch-worth-badge-text: {{ badge_text_color }};
              "
              {{ block.shopify_attributes }}
            >
              {% if enable_featured and featured_badge_text != blank %}
                <div class="trade-in-watch-worth__badge">
                  {{ featured_badge_text }}
                </div>
              {% endif %}

              {% if card_image != blank %}
                <div class="trade-in-watch-worth__card-image-wrap">
                  {{
                    card_image
                    | image_url: width: 500
                    | image_tag:
                      loading: 'lazy',
                      class: 'trade-in-watch-worth__card-image',
                      alt: card_title
                  }}
                </div>
              {% endif %}

              <div class="trade-in-watch-worth__card-content">
                {% if card_title != blank %}
                  <h3 class="trade-in-watch-worth__card-title">
                    {{ card_title }}
                  </h3>
                {% endif %}

                {% if card_price != blank or card_suffix != blank %}
                  <div class="trade-in-watch-worth__card-price-row">
                    {% if card_price != blank %}
                      <span class="trade-in-watch-worth__card-price">
                        {{ card_price }}
                      </span>
                    {% endif %}

                    {% if card_suffix != blank %}
                      <span class="trade-in-watch-worth__card-suffix">
                        {{ card_suffix }}
                      </span>
                    {% endif %}
                  </div>
                {% endif %}

                {% if card_description != blank %}
                  <div class="trade-in-watch-worth__card-description rte">
                    {{ card_description }}
                  </div>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

