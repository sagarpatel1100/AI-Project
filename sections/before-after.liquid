{% comment %}
Before / After Image Comparison Section (Dawn Compatible)
{% endcomment %}

<section class="section before-after">
  <div class="page-width">
    
    <div 
      class="before-after__container" 
      id="BeforeAfter-{{ section.id }}"
      data-start="{{ section.settings.slider_position }}"
    >

      <!-- AFTER IMAGE -->
      <div class="before-after__image before-after__image--after">
        {% if section.settings.after_image %}
          <img 
            src="{{ section.settings.after_image | image_url: width: 1500 }}"
            alt="After"
            loading="lazy"
          >
        {% endif %}
      </div>

      <!-- BEFORE IMAGE -->
      <div class="before-after__image before-after__image--before">
        {% if section.settings.before_image %}
          <img 
            src="{{ section.settings.before_image | image_url: width: 1500 }}"
            alt="Before"
            loading="lazy"
          >
        {% endif %}
      </div>

      <!-- LABELS -->
      {% if section.settings.show_labels %}
        <div class="before-after__labels">
          <span class="before-after__label before-after__label--before">
            {{ section.settings.before_label_text }}
          </span>
          <span class="before-after__label before-after__label--after">
            {{ section.settings.after_label_text }}
          </span>
        </div>
      {% endif %}

      <!-- SLIDER -->
      <div class="before-after__slider">
        <div class="before-after__handle"></div>
      </div>

    </div>

  </div>
</section>

<style>
.before-after {
  padding: 40px 0;
}

.before-after__container {
  position: relative;
  max-width: 900px;
  margin: 0 auto;
  overflow: hidden;
  cursor: ew-resize;
}

.before-after__image img {
  width: 100%;
  display: block;
  height: auto;
}

/* AFTER (base layer) */
.before-after__image--after {
  position: relative;
}

/* BEFORE (overlay) */
.before-after__image--before {
  position: absolute;
  top: 0;
  left: 0;
  width: 50%;
  overflow: hidden;
}

/* SLIDER LINE */
.before-after__slider {
  position: absolute;
  top: 0;
  left: 50%;
  width: 2px;
  height: 100%;
  background: #ffffff;
  transform: translateX(-50%);
  z-index: 2;
  transition: left 0.1s ease;
}

/* HANDLE */
.before-after__handle {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 36px;
  height: 36px;
  background: #000;
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

/* LABELS */
.before-after__labels {
  position: absolute;
  width: 100%;
  top: 10px;
  left: 0;
  display: flex;
  justify-content: space-between;
  padding: 0 10px;
  z-index: 3;
  pointer-events: none;
}

.before-after__label {
  background: rgba(0,0,0,0.6);
  color: #fff;
  font-size: 12px;
  padding: 6px 10px;
  border-radius: 4px;
}

/* RESPONSIVE */
@media screen and (max-width: 749px) {
  .before-after__handle {
    width: 28px;
    height: 28px;
  }

  .before-after__label {
    font-size: 11px;
    padding: 5px 8px;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const container = document.getElementById('BeforeAfter-{{ section.id }}');
  if (!container) return;

  const before = container.querySelector('.before-after__image--before');
  const slider = container.querySelector('.before-after__slider');

  let isDragging = false;

  // Set default position
  let start = parseFloat(container.dataset.start) || 50;
  updatePosition(start);

  function updatePosition(percent) {
    percent = Math.max(0, Math.min(100, percent));
    before.style.width = percent + '%';
    slider.style.left = percent + '%';
  }

  function getPosition(clientX) {
    const rect = container.getBoundingClientRect();
    return ((clientX - rect.left) / rect.width) * 100;
  }

  // Mouse
  container.addEventListener('mousedown', () => isDragging = true);
  window.addEventListener('mouseup', () => isDragging = false);
  window.addEventListener('mousemove', (e) => {
    if (!isDragging) return;
    updatePosition(getPosition(e.clientX));
  });

  // Touch
  container.addEventListener('touchstart', () => isDragging = true);
  window.addEventListener('touchend', () => isDragging = false);
  window.addEventListener('touchmove', (e) => {
    if (!isDragging) return;
    updatePosition(getPosition(e.touches[0].clientX));
  });
});
</script>

{% schema %}
{
  "name": "Before/After Comparison",
  "settings": [
    {
      "type": "image_picker",
      "id": "before_image",
      "label": "Before Image"
    },
    {
      "type": "image_picker",
      "id": "after_image",
      "label": "After Image"
    },
    {
      "type": "range",
      "id": "slider_position",
      "label": "Default Slider Position",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 50
    },
    {
      "type": "checkbox",
      "id": "show_labels",
      "label": "Show Labels",
      "default": true
    },
    {
      "type": "text",
      "id": "before_label_text",
      "label": "Before Label",
      "default": "Before"
    },
    {
      "type": "text",
      "id": "after_label_text",
      "label": "After Label",
      "default": "After"
    }
  ],
  "presets": [
    {
      "name": "Before/After Comparison"
    }
  ]
}
{% endschema %}