{% liquid
  assign heading = section.settings.heading
  assign description = section.settings.description

  assign section_bg_color = section.settings.section_bg_color
  assign heading_color = section.settings.heading_color
  assign description_color = section.settings.description_color
  assign stat_value_color = section.settings.stat_value_color
  assign stat_label_color = section.settings.stat_label_color

  assign content_max_width = section.settings.content_max_width
  assign section_padding_top = section.settings.section_padding_top
  assign section_padding_bottom = section.settings.section_padding_bottom
  assign section_padding_horizontal = section.settings.section_padding_horizontal

  assign section_padding_top_mobile = section.settings.section_padding_top_mobile
  assign section_padding_bottom_mobile = section.settings.section_padding_bottom_mobile
  assign section_padding_horizontal_mobile = section.settings.section_padding_horizontal_mobile

  assign stats_gap_desktop = section.settings.stats_gap_desktop
  assign stats_gap_mobile = section.settings.stats_gap_mobile

  assign heading_font_size_desktop = section.settings.heading_font_size_desktop
  assign heading_font_size_mobile = section.settings.heading_font_size_mobile
  assign description_font_size_desktop = section.settings.description_font_size_desktop
  assign description_font_size_mobile = section.settings.description_font_size_mobile
  assign stat_value_font_size_desktop = section.settings.stat_value_font_size_desktop
  assign stat_value_font_size_mobile = section.settings.stat_value_font_size_mobile
  assign stat_label_font_size_desktop = section.settings.stat_label_font_size_desktop
  assign stat_label_font_size_mobile = section.settings.stat_label_font_size_mobile

  

  assign heading_margin_bottom = section.settings.heading_margin_bottom
  assign description_margin_bottom = section.settings.description_margin_bottom

  assign has_intro = false
  if heading != blank or description != blank
    assign has_intro = true
  endif
%}

{{ 'section-trade-in-stats-band.css' | asset_url | stylesheet_tag }}

<section
  id="trade-in-stats-band-{{ section.id }}"
  class="trade-in-stats-band"
  style="
    --trade-in-stats-band-bg: {{ section_bg_color }};
    --trade-in-stats-band-heading-color: {{ heading_color }};
    --trade-in-stats-band-description-color: {{ description_color }};
    --trade-in-stats-band-stat-value-color: {{ stat_value_color }};
    --trade-in-stats-band-stat-label-color: {{ stat_label_color }};
    --trade-in-stats-band-content-max-width: {{ content_max_width }}px;
    --trade-in-stats-band-padding-top: {{ section_padding_top }}px;
    --trade-in-stats-band-padding-bottom: {{ section_padding_bottom }}px;
    --trade-in-stats-band-padding-horizontal: {{ section_padding_horizontal }}px;
    --trade-in-stats-band-padding-top-mobile: {{ section_padding_top_mobile }}px;
    --trade-in-stats-band-padding-bottom-mobile: {{ section_padding_bottom_mobile }}px;
    --trade-in-stats-band-padding-horizontal-mobile: {{ section_padding_horizontal_mobile }}px;
    --trade-in-stats-band-stats-gap-desktop: {{ stats_gap_desktop }}px;
    --trade-in-stats-band-stats-gap-mobile: {{ stats_gap_mobile }}px;
    --trade-in-stats-band-heading-size-desktop: {{ heading_font_size_desktop }}px;
    --trade-in-stats-band-heading-size-mobile: {{ heading_font_size_mobile }}px;
    --trade-in-stats-band-description-size-desktop: {{ description_font_size_desktop }}px;
    --trade-in-stats-band-description-size-mobile: {{ description_font_size_mobile }}px;
    --trade-in-stats-band-stat-value-size-desktop: {{ stat_value_font_size_desktop }}px;
    --trade-in-stats-band-stat-value-size-mobile: {{ stat_value_font_size_mobile }}px;
    --trade-in-stats-band-stat-label-size-desktop: {{ stat_label_font_size_desktop }}px;
    --trade-in-stats-band-stat-label-size-mobile: {{ stat_label_font_size_mobile }}px;
    --trade-in-stats-band-heading-margin-bottom: {{ heading_margin_bottom }}px;
    --trade-in-stats-band-description-margin-bottom: {{ description_margin_bottom }}px;
  "
>
  <div class="trade-in-stats-band__inner">
    <div class="trade-in-stats-band__container">
      {% if has_intro %}
        <div class="trade-in-stats-band__intro">
          {% if heading != blank %}
            <h2 class="trade-in-stats-band__heading">
              {{ heading }}
            </h2>
          {% endif %}

          {% if description != blank %}
            <div class="trade-in-stats-band__description rte">
              {{ description }}
            </div>
          {% endif %}
        </div>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <div class="trade-in-stats-band__stats" role="list">
          {% for block in section.blocks %}
            {% liquid
              assign stat_value = block.settings.stat_value
              assign stat_label = block.settings.stat_label
            %}

            {% if stat_value != blank or stat_label != blank %}
              <div class="trade-in-stats-band__stat" role="listitem" {{ block.shopify_attributes }}>
                {% if stat_value != blank %}
                  <div class="trade-in-stats-band__stat-value">
                    {{ stat_value }}
                  </div>
                {% endif %}

                {% if stat_label != blank %}
                  <div class="trade-in-stats-band__stat-label">
                    {{ stat_label }}
                  </div>
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

