{% schema %}
{
  "name": "Banner Home Responsive",
  "tag": "section",
  "class": "section-banner-responsive",
  "settings": [
    {
      "type": "url",
      "id": "banner_link",
      "label": "URL del banner",
      "default": "/"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Imagen para Desktop"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Imagen para Mobile"
    }
  ],
  "presets": [
    {
      "name": "Banner Responsive"
    }
  ]
}
{% endschema %}

{% stylesheet %}
<style>
  .section-banner-responsive {
    width: 100%;
  }

  .banner-link img {
    width: 100%;
    height: auto;
    display: none;
  }

  .banner-link .banner-desktop {
    display: block;
  }

  .banner-link .banner-mobile {
    display: none;
  }

  @media screen and (max-width: 768px) {
    .banner-link .banner-desktop {
      display: none;
    }
    .banner-link .banner-mobile {
      display: block;
    }
  }
</style>
{% endstylesheet %}

{% if section.settings.desktop_image or section.settings.mobile_image %}
  <a href="{{ section.settings.banner_link | escape }}" class="banner-link" title="Banner">
    {% if section.settings.desktop_image %}
      <img
        src="{{ section.settings.desktop_image | image_url }}"
        alt="Banner Desktop"
        class="banner-desktop"
        loading="lazy"
      >
    {% endif %}
    {% if section.settings.mobile_image %}
      <img
        src="{{ section.settings.mobile_image | image_url }}"
        alt="Banner Mobile"
        class="banner-mobile"
        loading="lazy"
      >
    {% endif %}
  </a>
{% endif %}