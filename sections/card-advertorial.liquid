{%- liquid
  assign desktop_image = section.settings.desktop_image
  assign mobile_image = section.settings.mobile_image
-%}

<section class="adventorial-banner-{{ section.id }}">
  <div class="adventorial-container">

    <div class="adventorial-image">
      {% if desktop_image != blank %}
        <picture>
          {% if mobile_image != blank %}
            <source
              media="(max-width: 768px)"
              srcset="{{ mobile_image | image_url: width: 800 }}"
            >
          {% endif %}

          <img
            src="{{ desktop_image | image_url: width: 1600 }}"
            alt="{{ desktop_image.alt | escape }}"
            loading="lazy"
          >
        </picture>
      {% endif %}
    </div>

    <div class="adventorial-content">

      {% if section.settings.title != blank %}
        <h2 class="adventorial-title">
          {{ section.settings.title }}
        </h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="adventorial-text">
          {{ section.settings.text }}
        </div>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <a
          class="adventorial-button"
          href="{{ section.settings.button_link }}"
          {% if section.settings.new_tab %}target="_blank"{% endif %}
        >
          <span>{{ section.settings.button_label }}</span>

          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M7 17L17 7M17 7H9M17 7V15"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"/>
          </svg>
        </a>
      {% endif %}

    </div>

  </div>
</section>


<style>

.adventorial-banner-{{ section.id }}{
  display:flex;
  justify-content:center;
  width:100%;
  margin:40px 0;
      padding: 0px 15px;
}

.adventorial-text p {
margin: 0px;
}

.adventorial-banner-{{ section.id }} .adventorial-container{
  max-width:840px;
  width:100%;
  background:#111;
  color:#fff;
}

.adventorial-banner-{{ section.id }} .adventorial-image img{
  width:100%;
  display:block;
}

.adventorial-banner-{{ section.id }} .adventorial-content{
  display:flex;
  flex-direction:column;
  padding:40px 60px;
  gap:30px;
}

.adventorial-banner-{{ section.id }} .adventorial-title{
  font-family:Inter, sans-serif;
  font-weight:700;
  font-size:34px;
  line-height:120%;
  margin:0;
}

.adventorial-banner-{{ section.id }} .adventorial-text{
  display:flex;
  flex-direction:column;
  gap:20px;
  font-family:Inter, sans-serif;
  font-weight:400;
  font-size:16px;
  line-height:100%;
}

.adventorial-banner-{{ section.id }} .adventorial-button{
  display:inline-flex;
  align-items:center;
  gap:10px;
  background:#FFC200;
  color:#000;
  padding:12px 24px;
  font-family:Inter, sans-serif;
  font-weight:700;
  font-size:18px;
  line-height:120%;
  text-transform:uppercase;
  text-decoration:none;
  width:fit-content;
  border-radius:6px;
}

.adventorial-banner-{{ section.id }} .adventorial-button svg{
  width:24px;
  height:24px;
}


/* MOBILE */

@media(max-width:768px){

  .adventorial-content {
  gap: 15px !important;
  }

  .adventorial-button {
  margin-top: 30px;
  }

  .adventorial-banner-{{ section.id }} .adventorial-content{
    padding:30px 20px;
  }

  .adventorial-banner-{{ section.id }} .adventorial-title{
    font-size:24px;
  }

  .adventorial-banner-{{ section.id }} .adventorial-text{
    font-size:15px;
  }

  .adventorial-banner-{{ section.id }} .adventorial-button{
    font-size:16px;
  }

}


body {
  background: #FAFAFA !important;
}
</style>


{% schema %}
{
  "name": "Adventorial Banner",
  "settings": [

    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },

    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },

    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Why reliability isn’t optional"
    },

    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },

    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },

    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },

    {
      "type": "checkbox",
      "id": "new_tab",
      "label": "Open link in new tab",
      "default": false
    }

  ],

  "presets": [
    {
      "name": "Advertorial Card"
    }
  ]
}
{% endschema %}