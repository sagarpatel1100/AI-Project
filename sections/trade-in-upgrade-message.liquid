      "min": 800,
      "max": 1600,
      "step": 20,
      "default": 1440
    },
    {
      "type": "range",
      "id": "heading_max_width",
      "label": "Heading max width desktop (1040px)",
      "min": 600,
      "max": 1200,
      "step": 20,
      "default": 1040
    },
    {
      "type": "range",
      "id": "description_max_width",
      "label": "Description max width desktop (1040px)",
      "min": 600,
      "max": 1200,
      "step": 20,
      "default": 1040
