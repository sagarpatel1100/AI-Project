      "min": 0,
      "max": 160,
      "step": 2,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding desktop (100px)",
      "min": 0,
      "max": 100,
      "step": 2,
