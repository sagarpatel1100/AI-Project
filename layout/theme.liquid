  if (e.target.closest(".ymal-next")) {
    console.log("➡️ Next");
    slider.scrollBy({
      left: scrollAmount,
      behavior: "smooth"
    });
  }

  if (e.target.closest(".ymal-prev")) {
    console.log("⬅️ Prev");
    slider.scrollBy({
      left: -scrollAmount,
      behavior: "smooth"
    });
  }
});
</script>
  </body>        
</html>

