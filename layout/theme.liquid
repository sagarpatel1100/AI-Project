    <script defer>
      console.log('ConvertMate 3s wait')
      const LOAD_DELAY = 3000;

class ScriptLoader {
  constructor() {
    this.loaded = false;
    this.bindEvents();
  }

  loadScripts(immediate = false) {
    if (this.loaded) return;
    
    const loadAction = () => {
      this.loaded = true;
      this.updateElements('script', 'data-src', 'src');
      this.updateElements('link', 'data-href', 'href');
      this.dispatchLoadEvents();
    };

    immediate ? loadAction() : setTimeout(loadAction, LOAD_DELAY);
  }

  updateElements(tagName, dataAttr, newAttr) {
    const elements = document.getElementsByTagName(tagName);
    Array.from(elements).forEach(element => {
      const dataValue = element.getAttribute(dataAttr);
      if (dataValue) {
        element.setAttribute(newAttr, dataValue);
        element.removeAttribute(dataAttr);
      }
    });
  }

  dispatchLoadEvents() {
    ['StartAsyncLoading', 'StartKernelLoading'].forEach(eventName => {
      document.dispatchEvent(new CustomEvent(eventName));
    });
  }

  bindEvents() {
    const events = ['mousedown', 'mousemove', 'keydown', 'scroll', 'touchstart', 'click', 'keypress', 'touchmove'];
    events.forEach(event => {
      window.addEventListener(event, () => this.loadScripts(true), { once: true });
    });
    
    ['DOMContentLoaded', 'load'].forEach(event => {
      window.addEventListener(event, () => this.loadScripts());
    });
  }
}

new ScriptLoader();
      </script>
