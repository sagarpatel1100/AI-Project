          "settings": {
            "title": "Shipping"
          }
        },
        "1660076465f1e811f4-1": {
          "type": "question",
          "disabled": true,
          "settings": {
            "title": "Are these smartwatches indestructible?",
            "answer": "<p>We guarantee you'll receive the stronger smartwatch you've ever had. However,don't submit it to abuse tests such as as throwing it from a 30th floor or test it with a saw to see if it holds up (This is a true story 🥴)</p>"
          }
        },
        "1660076465f1e811f4-2": {
          "type": "question",
          "settings": {
            "title": "Can I answer calls, send messages and speak with the Carbinox Smartwatches?",
            "answer": "<p>The Carbinox Ivy does not include Bluetooth Calling Technology, you can only receive notifications for the incoming call. The same with text messages and social media notifications.</p>"
          }
        },
        "1660076465f1e811f4-4": {
          "type": "question",
          "settings": {
            "title": "Is this smartwatch waterproof?",
            "answer": "<p>Yes, the Carbinox Ivy is fully Waterproof. 5ATM & IP69K Technology.</p>"
          }
        },
        "b94b4ba9-d47e-4003-8a27-597acb9b7952": {
          "type": "question",
          "settings": {
            "title": "Is my smartphone compatible with the Carbinox Ivy?",
            "answer": "<p>Yes. The Carbinox Ivy works with any Apple or Android device through our Carbinox App. Available in all app stores.</p>"
          }
        },
        "91345035-5b96-4951-8a1e-d62883b97573": {
          "type": "question",
          "settings": {
            "title": "Will my wrist fist on the Carbinox smartwatches?",
            "answer": "<p>Yes, all of our smartwatches have adjustable bands that can fit with any wrist.</p>"
          }
        },
        "b1b69a37-56f7-497e-b973-6abbf1bb8a51": {
          "type": "question",
          "settings": {
            "title": "Do you offer any guarantees?",
            "answer": "<p>Of course! All our smartwatches are covered with 45-Day Risk Free Guarantee in case that they don't fit your needs, as well as full protection from any software or internal issues. If this happens, we'll provide you a replacement at no cost.</p>"
          }
        },
        "08cad6de-133a-438f-9a28-8990559de84f": {
          "type": "question",
          "settings": {
            "title": "How long does it take to charge fully?",
            "answer": "<p>Your X-Ranger will be fully charged after approximately 2-3 hours and lasts up to 10 days within a single cycle.</p>"
          }
        },
        "7c26ebf9-9f0f-4f89-a025-4868a8e8855f": {
          "type": "question",
          "settings": {
            "title": "How can I contact Carbinox?",
            "answer": "<p>If you have any questions or doubts, please don't hesitate to send us an e-mail to <strong>info@shopcarbinox.com</strong> or through our social media channels such as Facebook or Instagram.</p>"
          }
        }
      },
