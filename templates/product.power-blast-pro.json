=\"24\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M4 3.532c0-1.554 1.696-2.514 3.029-1.715l14.113 8.468c1.294.777 1.294 2.653 0 3.43L7.029 22.183c-1.333.8-3.029-.16-3.029-1.715V3.532Z\" fill=\"#FFFFFF\"></path></svg>\n        </div>\n      </div>\n    </div>\n\n    <!-- Slide 3 -->\n    <div class=\"carousel-slide\">\n      <div class=\"video-wrapper\">\n        <video\n          src=\"https://cdn.shopify.com/videos/c/o/v/e0844d4039244680b71376b45b99bdca.mp4\"\n          poster=\"https://cdn.shopify.com/s/files/1/0049/0533/6935/files/poster-blastbeam-3_1.webp?v=1760718887\"\n          playsinline\n          controlsList=\"nodownload noremoteplayback noplaybackrate nopictureinpicture\"\n          preload=\"auto\">\n        </video>\n        <div class=\"play-button\">\n          <svg class=\"\" xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M4 3.532c0-1.554 1.696-2.514 3.029-1.715l14.113 8.468c1.294.777 1.294 2.653 0 3.43L7.029 22.183c-1.333.8-3.029-.16-3.029-1.715V3.532Z\" fill=\"#FFFFFF\"></path></svg>\n        </div>\n      </div>\n    </div>\n\n    <!-- Slide 4 -->\n    <div class=\"carousel-slide\">\n      <div class=\"video-wrapper\">\n        <video\n          src=\"https://cdn.shopify.com/videos/c/o/v/f3b4a85db1404fcaa84bbf5653e9dcbf.mp4\"\n          poster=\"https://cdn.shopify.com/s/files/1/0049/0533/6935/files/poster-blastbeam-4_1.webp?v=1760718887\"\n          playsinline\n          controlsList=\"nodownload noremoteplayback noplaybackrate nopictureinpicture\"\n          preload=\"auto\">\n        </video>\n        <div class=\"play-button\">\n          <svg class=\"\" xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M4 3.532c0-1.554 1.696-2.514 3.029-1.715l14.113 8.468c1.294.777 1.294 2.653 0 3.43L7.029 22.183c-1.333.8-3.029-.16-3.029-1.715V3.532Z\" fill=\"#FFFFFF\"></path></svg>\n        </div>\n      </div>\n    </div>\n\n    <!-- Slide 5 -->\n    <div class=\"carousel-slide\">\n      <div class=\"video-wrapper\">\n        <video\n          src=\"https://cdn.shopify.com/videos/c/o/v/bab1e56b1c74459789df9f1e968c108f.mp4\"\n          poster=\"https://cdn.shopify.com/s/files/1/0049/0533/6935/files/poster-blastbeam-5_1.webp?v=1760718887\"\n          playsinline\n          controlsList=\"nodownload noremoteplayback noplaybackrate nopictureinpicture\"\n          preload=\"auto\">\n        </video>\n        <div class=\"play-button\">\n          <svg class=\"\" xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M4 3.532c0-1.554 1.696-2.514 3.029-1.715l14.113 8.468c1.294.777 1.294 2.653 0 3.43L7.029 22.183c-1.333.8-3.029-.16-3.029-1.715V3.532Z\" fill=\"#FFFFFF\"></path></svg>\n        </div>\n      </div>\n    </div>\n\n  </div>\n\n  <button class=\"carousel-arrow right\" aria-label=\"Next\">\n    <svg width=\"10\" height=\"18\" viewBox=\"0 0 10 18\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M7.797 16.664.648 9.204A1.071 1.071 0 0 1 .375 8.5c0-.195.078-.43.234-.625L7.758.415a.932.932 0 0 1 1.328-.04c.39.352.39.938.039 1.328L2.602 8.5l6.562 6.875a.932.932 0 0 1-.039 1.328.932.932 0 0 1-1.328-.039Z\" fill=\"#090A0B\"></path></svg>\n  </button>\n</div>\n\n<style>\n.video-carousel-pdp {\n  position: relative;\n  width: 100%;\nmax-width: calc(var(--grid-column-width) * 8 + var(--grid-gap) * 7);\n  overflow: hidden;\n}\n\n.video-carousel-pdp .carousel-track {\n  display: flex;\n  gap: 6px;\n  overflow-x: auto;\n  scroll-behavior: smooth;\n  margin: 0px 30px;\n   scrollbar-width: none; /* Firefox */\n  -ms-overflow-style: none; /* IE y Edge antiguos */\n}\n\n.video-carousel-pdp .carousel-slide {\n  flex: 0 0 auto;\n  width: 200px;\n}\n\n.video-carousel-pdp .video-wrapper {\n  position: relative;\n  aspect-ratio: 9 / 16;\n  background: #000;\n  border-radius: 2px;\n  overflow: hidden;\n}\n.video-wrapper video::-webkit-media-controls-picture-in-picture-button {\n  display: none;\n}\n\n\n.video-carousel-pdp video {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  display: block;\n}\n\n.video-carousel-pdp .play-button {\n\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    transform: translate(-50%, -50%);\n    font-size: 26px !important;\n    padding: 5px 18px;\n    padding-top: 10px;\n    color: white;\n    background: transparent;\n    border: 2px solid white;\n    border-radius: 50%;\n    cursor: pointer;\n}\n\n.video-carousel-pdp .carousel-arrow {\n  position: absolute;\n  top: 50%;\n  transform: translateY(-50%);\n  background: white;\n  border: none;\n  color: black;\n  cursor: pointer;\n  width: 30px;\n  height: 30px;\n  z-index: 10;\n  border-radius: 999px;\n}\n\n.video-carousel-pdp .carousel-arrow.left {\n  left: 0px;\n}\n\n.video-carousel-pdp .carousel-arrow.right {\n  right: 0px;\n  transform: scaleX(-1);\n}\n\n.video-carousel-pdp .carousel-arrow.left svg {\n  position: relative;\n  right: -5px;\n}\n\n.video-carousel-pdp .carousel-arrow.right svg {\n  position: relative;\n  left: 5px;\n}\n@media (max-width: 1000px) {\n.video-carousel-pdp {\nmax-width: calc(100vw - 48px);\n}\n}\n@media (max-width: 768px) {\n  .video-carousel-pdp .carousel-slide {\n    width: 150px;\n  }\n  .video-carousel-pdp .carousel-arrow{\n    display: none;\n  }\n  .video-carousel-pdp .carousel-track {\n  margin: 0px;\n}\n}\n</style>\n\n<script>\ndocument.addEventListener(\"DOMContentLoaded\", function() {\n  const carousel = document.querySelector(\".video-carousel-pdp\");\n  const track = carousel.querySelector(\".carousel-track\");\n  const leftBtn = carousel.querySelector(\".carousel-arrow.left\");\n  const rightBtn = carousel.querySelector(\".carousel-arrow.right\");\n\n  leftBtn.addEventListener(\"click\", () => {\n    track.scrollBy({ left: -200, behavior: \"smooth\" });\n  });\n\n  rightBtn.addEventListener(\"click\", () => {\n    track.scrollBy({ left: 200, behavior: \"smooth\" });\n  });\n\n  carousel.querySelectorAll(\".video-wrapper\").forEach(wrapper => {\n    const video = wrapper.querySelector(\"video\");\n    const playBtn = wrapper.querySelector(\".play-button\");\n    video.disablePictureInPicture = true;\n\n    playBtn.addEventListener(\"click\", () => {\n      if (video.paused) {\n        video.play();\n        playBtn.style.display = \"none\";\n        video.setAttribute(\"controls\", \"controls\"); // Muestra controles\n    } else {\n        video.pause();\n        playBtn.style.display = \"block\";\n        video.removeAttribute(\"controls\", \"controls\"); // Muestra controles\n      }\n    });\n\n    video.addEventListener(\"ended\", () => {\n      playBtn.style.display = \"block\";\n    });\n  });\n});\n</script>"
          }
