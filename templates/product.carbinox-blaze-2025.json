    "166007646669623aaa": {
      "type": "faq",
      "blocks": {
        "1660076465f1e811f4-0": {
          "type": "category",
          "disabled": true,
          "settings": {
            "title": "Shipping"
          }
        },
        "1660076465f1e811f4-1": {
          "type": "question",
          "disabled": true,
          "settings": {
            "title": "Are these smartwatches indestructible?",
            "answer": "<p>We guarantee you'll receive the stronger smartwatch you've ever had. However,don't submit it to abuse tests such as as throwing it from a 30th floor or test it with a saw to see if it holds up (This is a true story 🥴)</p>"
          }
        },
        "1660076465f1e811f4-2": {
          "type": "question",
          "settings": {
            "title": "CAN I ANSWER AND MAKE CALLS WITH THE CARBINOX BLAZE?",
            "answer": "<p>Yes, you can answer and dial calls with your Carbinox Blaze. Just pair it with your phone and make sure Bluetooth is on.</p>"
          }
        },
        "7c26ebf9-9f0f-4f89-a025-4868a8e8855f": {
          "type": "question",
          "settings": {
            "title": "HOW DOES THE GPS WORK?",
            "answer": "<p>To ensure accurate tracking of your activities, the GPS functionality on the Carbinox Blaze works in conjunction with the Carbinox Pro App. When you select any sport mode on your smartwatch, the device relies on your smartphone’s GPS for precise location data. This allows the smartwatch to accurately track your movements, speed, and distance during outdoor activities.</p>"
          }
        },
        "9e45f6ba-ce45-4182-ab2f-4f8bcd8f6681": {
          "type": "question",
          "settings": {
            "title": "HOW DOES THE AI ASSISTANT WORKS TO SEND TEXT MESSAGES?",
            "answer": "<p><strong>Access the Voice Assistant:</strong> Simply navigate to the voice assistant feature on your Carbinox Blaze smartwatch by selecting it from the main menu.</p><p><strong>Activate Voice Commands:</strong> Once in the voice assistant menu, tap the screen to speak.</p><p><strong>Send a Text Message:</strong> After activating the assistant, you can send a text message by saying the command, for example, “<strong>Send a text message to [name] saying [message].</strong>”</p><p><strong>Message Sent:</strong> The AI assistant will instantly pair with your smartphone and send the message as instructed.<br/><br/><strong>You can also make calls with the AI voice assistant. Just follow the same steps as the ones to send a message but instead, say \"Call [name]\".</strong></p><p><strong>Important Disclaimer:</strong><br/>While the AI voice assistant is highly responsive, it is also very sensitive. This means that in some cases, the message <strong>may not be delivered exactly as you intended.</strong> Always double-check your command to ensure it’s understood correctly. We recommend speaking clearly and confirming any important messages.</p>"
          }
        },
        "1660076465f1e811f4-4": {
          "type": "question",
          "settings": {
            "title": "ARE THE CARBINOX BLAZE WATCHES WATERPROOF?",
            "answer": "<p>Yes, the Carbinox Vortex is fully Waterproof with IP69K and 5ATM technology.</p>"
          }
        },
        "b94b4ba9-d47e-4003-8a27-597acb9b7952": {
          "type": "question",
          "settings": {
            "title": "IS MY SMARTPHONE COMPATIBLE WITH THE CARBINOX BLAZE WATCHES?",
            "answer": "<p>Yes. The Carbinox Blaze watches work with any Apple or Android device through the <strong>CARBINOX PRO APP.</strong></p>"
          }
        },
        "91345035-5b96-4951-8a1e-d62883b97573": {
          "type": "question",
          "settings": {
            "title": "WILL THE CARBINOX BLAZE FIT MY WRIST?",
            "answer": "<p>Yes, all of our smartwatches come with adjustable bands that can fit any wrist.</p>"
          }
        },
        "b1b69a37-56f7-497e-b973-6abbf1bb8a51": {
          "type": "question",
          "settings": {
            "title": "DO YOU OFFER GUARANTEES?",
            "answer": "<p>Of course! All of our smartwatches are covered with 45-Day Risk Free Trial, and Lifetime Warranty in case they don't fit your needs or if you face any software or internal issues. If this happens, we'll provide you a replacement at no cost.</p>"
          }
        },
        "08cad6de-133a-438f-9a28-8990559de84f": {
          "type": "question",
          "settings": {
            "title": "HOW LONG DO THE CARBINOX BLAZE TAKE TO FULLY CHARGE?",
            "answer": "<p>The Carbinox Blaze will be fully charged after approximately 90 minutes and lasts up to 14 days within a single cycle.</p>"
          }
        }
      },
