        "text_C2Ndos89nB4udHVm": "<p>CARBINOX ELITE PRIVATE CLUB</p>",
        "text_htu3c5flm6TMwlaX": "<p>Limitless Benefits,</p>",
        "text_2AgXpj1t8PXv9fYg": "<p>Only for the Elite</p>",
        "text_oXQjm06jw9hDZGas": "<p>Unlock exclusive perks that elevate your experience to a whole new level.</p>",
        "text_a2lgFlk7To7N1MVe": "<p>STORE CREDIT EVERY 3 MONTHS</p>",
        "text_uVybqxQIVHvbJvfy": "<p>What you pay, goes back to you!</p>",
        "text_733ElbsrTXeI13FW": "<p>lifetime replacements</p>",
        "text_lagHA7WdOV1RizeC": "<p>For all your Carbinox products.</p>",
