      "type": "adv-main-title",
      "name": "Advertorial Article Title",
      "settings": {
        "title": "Is The Carbinox Blaze Worth It? My Honest Review After 6 Months Of Sawdust, Sweat & Saltwater",
        "show_author": true,
        "author_image": "shopify://shop_images/Ellipse_2.png",
        "author_text": "I’m a woodworker who rides, hikes, hunts, surfs, and hits the gym.\nHere’s how this “work watch” actually held up."
      }
