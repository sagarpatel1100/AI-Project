r-radius: 2px;\n  font-size: 9px;\n  position: absolute;\n  top: -8px;\n  left: 50%;\n  transform: translateX(-50%);\n  white-space: nowrap;\n  z-index: 1;\n}\n{% if settings.promo-on %}\n.gift-badge {\n  background: #FFC200;\ncolor: black;\n}\n{% endif %}\n\n.gift-item img {\n  width: 100%;\n  height: 100px;\n  object-fit: contain;\n  display: block;\n}\n\n.gift-item p {\n  font-size: 12px;\n  margin: 0;\n  font-weight: 400;\n  line-height: 1.2;\n  min-height: 30px;\n  display: flex;\n  align-items: center;\n  text-align: center;\n}\n\n.product-meta {\n  margin-top: 0px;\n  margin-bottom: -30px !important;\n  padding-bottom: 0px;\n  border: 0px;\n}\n\n.template-product .product-form__variants div.product-form__option-info {\n  justify-content: flex-start !important;\n}\n\n.product-form__option-selector:nth-of-type(2) {\n  display: none;\n}\n\ndiv.product-form__option-info {\n  justify-content: left !important;\n}\n\n/* Mobile styles */\n@media (max-width: 768px) {\n.badge-text__free-gifts {\nfont-size: 16px !important;\npadding-top: 7px !important;\n}\n  .product-form__buy-buttons {\n    margin-top: -5px;\n  }\n  #free-gifts-banner {\n    margin-top: 15px;\n  }\n  .payments-badge-pdp {\n    margin-top: 15px !important;\n  }\n  .product-form__payment-container {\n    margin-bottom: 8px;\n  }\n  .product-form__variants{\n    margin-bottom: -10px;\n    margin-top: 15px;\n  }\n  .free-gifts {\n    margin: 10px 0px;\n    padding: 10px 12px;\n  }\n  \n  .free-gifts__header {\n    margin-bottom: 14px;\n  }\n  \n  .gift-item img {\n    height: 80px;\n  }\n  \n  .gift-item p {\n    font-size: 11px;\n    min-height: 26px;\n  }\n  \n  .gift-badge {\n    font-size: 8px !important;\n    padding: 1px 3px;\n  }\n  \n  .product-meta {\n    margin-bottom: -20px !important;\n  }\n  .free-gifts__items {\n    gap: 5px;\n  }\n}\n\n/* Desktop - mantener compacto */\n.shipping_polices_par {\nmargin-top: 10px;\n}\n@media (min-width: 769px) {\n.payments-badge-pdp {\n  margin-top: 5px;\n}\n#AddToCart {\nmargin-bottom: 15px !important;\n}\n#free-gifts-banner {\n  margin-top: 30px;\n}\n.product-form__variants{\nmargin-top: 0px;\nmargin-bottom: -30px;\n}\n  .free-gifts {\n    max-width: 500px !important;\n    padding: 12px 20px;\n    margin: 15px auto;\n  }\n  \n  .free-gifts__header {\n    font-size: 16px !important;\n    margin-bottom: 20px;\n  }\n  \n  .gift-item img {\n    height: 110px;\n  }\n  \n  .gift-item p {\n    font-size: 13px;\n  }\n}\n\n#stock-left {\n  display: inline-block !important;\n  transition: transform 0.4s ease, opacity 0.4s ease !important;\n}\n\n#stock-left.changing {\n  transform: scale(1.25) !important;\n  opacity: 0.4 !important;\n}\n\n#stock-left {\n  display: inline-block !important;\n  transition: transform 0.4s ease, opacity 0.4s ease, background 0.4s ease !important;\n}\n\n/* animación del cambio */\n#stock-left.changing {\n  transform: scale(1.25) !important;\n  opacity: 0.4 !important;\n}\n\n.badge-text__free-gifts {\nbackground: #E70000 !important;\ncolor: white !important;\nborder: 1px solid #E70000 !important;\n}\n\n/* 🔥 cuando está por debajo de 120 */\n#stock-left {\n  background: #E70000 !important;  /* rojo alerta */\n  color: white !important;\n}\n\n@media (min-width: 1000px) {\n#free-gifts-banner {\n  margin-bottom: -30px;\n}\n}\n</style>\n{% comment %}\n<script>\ndocument.addEventListener(\"DOMContentLoaded\", () => {\n  \n  const el = document.querySelector(\"#stock-left\");\n\n  const START = 500;\n  const END = 2;\n\n  // 🔥 Obtener segundos del día en GMT+7\n  function getSecondsTodayGMT7() {\n    const now = new Date();\n\n    // tiempo local en ms\n    const localTime = now.getTime();\n\n    // diferencia entre local y UTC en ms\n    const localOffset = now.getTimezoneOffset() * 60000;\n\n    // hora actual convertida a GMT+7\n    const gmt7Time = localTime + localOffset + (7 * 3600000);\n\n    const gmt7Date = new Date(gmt7Time);\n\n    return (\n      gmt7Date.getUTCHours() * 3600 +\n      gmt7Date.getUTCMinutes() * 60 +\n      gmt7Date.getUTCSeconds()\n    );\n  }\n\n  function calculateUnits() {\n    const secondsToday = getSecondsTodayGMT7();\n    const totalSecondsDay = 86400;\n\n    // progreso normalizado\n    const progress = secondsToday / totalSecondsDay;\n\n    // stock lineal de 500 → 2\n    let units = Math.round(START - (START - END) * progress);\n\n    // reinicia cuando llega a 2\n    if (units < END) units = START;\n\n    return units;\n  }\n\n  function updateDisplay() {\n    const units = calculateUnits();\n\n    el.textContent = `${units} LEFT`;\n\n    if (units <= 120) {\n      el.classList.add(\"last-units\");\n    } else {\n      el.classList.remove(\"last-units\");\n    }\n  }\n\n  updateDisplay();\n  setInterval(updateDisplay, 1000);\n});\n</script>\n{% endcomment %}"
