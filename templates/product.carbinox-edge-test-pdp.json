    "instant_f_qsl5v_ii_zqoj_lz9_f_QjJ3aq": {
      "type": "instant-fQsl5vIIZqojLZ9F",
      "name": "Still skeptical",
      "settings": {
        "text_UNqsO6pQ2AodLuje": "<p>Still Skeptical?</p>",
        "text_jBpvFjCHIzwVj8vg": "<p>Protected for Life. No Fine Print.</p>",
        "text_9JiklYXCQhdQcv7g": "<p>Take the Carbinox Edge for a test run, if you don’t love it, <strong>return it within 45 days, no questions asked.</strong></p>",
        "text_ECg5P6sURkzl3Psl": "<p>Unlimited Replacements</p>",
        "text_NXjNgHYzPwmCDGzd": "<p>for an entire Year.</p>",
        "text_VdJYYkELN6DmlQ5a": "<p>You’re fully covered for 365 full days against any internal or external defects, no questions asked.</p>",
        "text_5KaWEgatKjHDHcgA": "<p><strong>NO B.S. LIFETIME WARRANTY:</strong></p>",
        "text_H5Y30nQIWOzVq258": "<p><strong>BREAK IT. WE'LL REPLACE IT.</strong></p>",
        "text_YWg8AScJ8ZjIlms0": "<p>If your watch ever fails, we'll send you a new one FOR FREE. No questions asked.</p>",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
