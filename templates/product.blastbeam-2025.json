        "liquid_UwKrnt": {
          "type": "liquid",
          "name": "Buy Box Variants",
          "settings": {
            "liquid": "<div class=\"pack-list ultimate-pack\">\n      <p class=\"congrats-p\">\n<img alt=\"save money\" width=\"22\" height=\"22\" src=\"https://cdn.shopify.com/s/files/1/0049/0533/6935/files/icon-congrats.png?v=1755265589\"/>\nCongrats! You’re saving <span class=\"congrats-saving\">$110</span>TODAY!</p>\n</div>\n <div class=\"pack-list starter-pack\">\n      <p class=\"congrats-p\">\n<img alt=\"save money\"  width=\"22\" height=\"22\" src=\"https://cdn.shopify.com/s/files/1/0049/0533/6935/files/icon-congrats.png?v=1755265589\"/>\nCongrats! You’re saving <span class=\"congrats-saving\">$30</span>TODAY!</p>\n\n  </div>\n<div class=\"pack-list double-pack\">\n\n      <p class=\"congrats-p\">\n<img alt=\"save money\"  width=\"22\" height=\"22\" src=\"https://cdn.shopify.com/s/files/1/0049/0533/6935/files/icon-congrats.png?v=1755265589\"/>\nCongrats! You’re saving <span class=\"congrats-saving\">$180</span>TODAY!</p>\n        </div>\n\n\n\n\n\n<script>\n  document.addEventListener(\"DOMContentLoaded\", function () {\nconst featureList = document.querySelector(\".feature-list\");\n    const productTitle = document.querySelector(\".product-meta__title\");\n\n    if (featureList && productTitle) {\n      productTitle.insertAdjacentElement(\"afterend\", featureList);\nfeatureList.style.marginBottom = \"13px\"\n    }\n\n  // Procesar opciones\n  const optionContainers = document.querySelectorAll(\".product-form__option-info\");\n\n  optionContainers.forEach((container, index) => {\n    const labelEl = container.querySelector(\".product-form__option-name\");\n    const valueEl = container.querySelector(\".product-form__option-value\");\n\n    if (labelEl && valueEl) {\n      labelEl.textContent = labelEl.textContent.replace(/^\\s*[\\d#*️⃣️]+/g, '').trim();\n      if (index === 1) {\n      }\n      valueEl.style.fontWeight = \"500\";\n    }\n  });\n\n  const swatchLabels = document.querySelectorAll(\"label.block-swatch__item\");\n\n  swatchLabels.forEach((label) => {\n    const text = label.textContent;\n\n    if (text.includes(\"Starter\")) {\n      label.setAttribute(\"data-pack\", \"starter-pack\");\n    }\n\n    if (text.includes(\"Triple\")) {\n      label.setAttribute(\"data-pack\", \"ultimate-pack\");\n    }\n\n    if (text.includes(\"Famil\")) {\n      label.setAttribute(\"data-pack\", \"double-pack\");\n    }\n  });\n\nfunction detectWatchTypeAndUpdateText() {\n  const selectedRadio = document.querySelector('.block-swatch__radio:checked');\n  if (!selectedRadio) return;\n\n  const typeValue = selectedRadio.value.trim();\n  const formattedText =\n    typeValue.includes(\"Type S\")\n      ? '1 Carbinox Blaze Type S'\n      : typeValue.includes(\"Type R\")\n      ? '1 Carbinox Blaze Type R'\n      : '1 Carbinox Blaze';\n\n  // Modificar solo en packs visibles que NO sean double-pack\n  const visiblePackLists = document.querySelectorAll('.pack-list');\n  visiblePackLists.forEach(pack => {\n    if (pack.style.display === \"block\" && !pack.classList.contains(\"double-pack\")) {\n      const lis = pack.querySelectorAll('ul li .pack-li-content p:first-child');\n      lis.forEach(p => {\n        if (p.textContent.trim().startsWith(\"1 Carbinox Blaze\")) {\n          p.innerHTML = `<span class=\"icon\"></span>${formattedText}`;\n        }\n      });\n    }\n  });\n}\n\n  // Mostrar pack correspondiente y actualizar textos según tipo\n  function updatePackVisibility(selectedPack) {\n    const packs = document.querySelectorAll(\".pack-list\");\n    packs.forEach((pack) => {\n      if (pack.classList.contains(selectedPack)) {\n        pack.style.display = \"block\";\n      } else {\n        pack.style.display = \"none\";\n      }\n    });\n\n    // 👇 Muy importante: actualizar tipo de reloj solo después de mostrar\n    detectWatchTypeAndUpdateText();\n  }\n\n  // Detectar clic en swatches\n  const swatches = document.querySelectorAll(\"label.block-swatch__item[data-pack]\");\n  swatches.forEach((swatch) => {\n    swatch.addEventListener(\"click\", () => {\n      const selected = swatch.getAttribute(\"data-pack\");\n      updatePackVisibility(selected);\n    });\n  });\n// Escuchar cambios en el tipo de reloj (Type S / Type R)\ndocument.querySelectorAll('.block-swatch__radio').forEach(radio => {\n  radio.addEventListener('change', () => {\n    detectWatchTypeAndUpdateText();\n  });\n});\n  // Al seleccionar por primera vez\n  const firstSwatch = document.querySelector(\"label.block-swatch__item[data-pack]\");\n  if (firstSwatch) {\n    const firstRadio = firstSwatch.previousElementSibling;\n    if (firstRadio && firstRadio.type === 'radio') {\n      firstRadio.checked = true;\n      const selected = firstSwatch.getAttribute(\"data-pack\");\n      updatePackVisibility(selected);\n    }\n  }\n});\n</script>\n\n<style>\n.block-swatch{\nwidth: 100%;\n}\n.block-swatch:has(.pack-item) {\n  width: auto !important;\n}\n.block-swatch__item{\nfont-weight: 400 !important;\nmargin: 0px !important;\nwidth: 100%!important;\nfont-size: 14px !important;\npadding: 10px !important;\nposition: relative;\nmargin-top: 8px !important;\nbackground-color: #F9F9F9 !important;\nborder: 1px solid #D4D4D4;\nborder-radius: 4px !important;\ndisplay: flex;\nflex-direction: column;\njustify-content: center;\nalign-items: center;\nline-height: 1.2 !important;\n}\n.block-swatch-list{\nflex-wrap: unset !important;\ngap: 8px;\njustify-content: center;\nmax-width: 100%;\nmargin: auto;\n}\n.block-swatch__item:after {border-radius: 4px !important;\n}\n.block-swatch__radio:checked + label {\nfont-weight: 500 !important;\n}\n.block-swatch__radio:checked + .block-swatch__item[data-pack] {\nborder-radius: 4px !important;\n}\n\n.block-swatch__item[data-pack]::after {\nborder-radius: 4px !important;\n\n}\n.save-badge{\nfont-size: 10px;\npadding: 2px 6px;\n}\n\n .best-value-badge {\n    position: absolute;\n    top: -17px;\n    left: 50%;\n    transform: translateX(-50%);\n    background-color: #95C122;\n    color: white;\n    font-weight: 600;\n    font-size: 10px;\n    padding: 2px 6px;\n    border-radius: 4px 4px 0px 0px;\n    z-index: 1;\nwidth: max-content;\n  }\n  .type-s-image,\n  .type-r-image,\n  .starter-image,\n  .ultimate-image,\n  .double-image {\n    width: 64px;\n    height: 64px;\n    object-fit: contain;\n    margin: auto;\n    display: inline-block;\n    vertical-align: middle;\n  }\n\n.pack-list p{\nmargin: 0px;\n}\n.pack-list ul {\n  list-style: none;\n  padding: 0;\n  margin: 0;\nfont-size: 14px;\n}\n\n.pack-list li {\n  display: flex;\n  align-items: center;\n  gap: 5px;\njustify-content: space-between;\n  margin-bottom: 2px;\n  font-family: sans-serif;\n  font-size: 14px;\nwidth: 100%;\nborder-bottom: 0.5px solid #D4D4D4;\n}\n\n.pack-list .icon {\n  width: 16px;\n  height: 16px;\nmargin-right: 4px;\n  display: inline-block;\n  background-image: url('data:image/svg+xml;utf8,<svg width=\"16\" height=\"17\" viewBox=\"0 0 16 17\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M14.6673 8.50016C14.6673 12.1822 11.6827 15.1668 8.00065 15.1668C4.31865 15.1668 1.33398 12.1822 1.33398 8.50016C1.33398 4.81816 4.31865 1.8335 8.00065 1.8335C11.6827 1.8335 14.6673 4.81816 14.6673 8.50016Z\" fill=\"%2395C122\"/><path d=\"M10.6868 6.47972C10.7804 6.57347 10.833 6.70056 10.833 6.83306C10.833 6.96556 10.7804 7.09264 10.6868 7.18639L7.35344 10.5197C7.25969 10.6134 7.1326 10.6659 7.0001 10.6659C6.8676 10.6659 6.74052 10.6134 6.64677 10.5197L5.31344 9.18639C5.26431 9.14061 5.22491 9.08541 5.19758 9.02408C5.17025 8.96275 5.15556 8.89654 5.15437 8.8294C5.15319 8.76227 5.16554 8.69558 5.19069 8.63332C5.21583 8.57107 5.25326 8.51451 5.30074 8.46703C5.34822 8.41955 5.40478 8.38212 5.46704 8.35697C5.5293 8.33183 5.59598 8.31948 5.66312 8.32066C5.73025 8.32185 5.79646 8.33654 5.85779 8.36387C5.91913 8.3912 5.97433 8.4306 6.0201 8.47972L7.0001 9.45972L8.4901 7.96972L9.9801 6.47972C10.0739 6.38609 10.2009 6.3335 10.3334 6.3335C10.4659 6.3335 10.593 6.38609 10.6868 6.47972Z\" fill=\"bla