    "trade_accordion_mgN3ky": {
      "type": "trade-accordion",
      "blocks": {
        "faq_ty7xLE": {
          "type": "faq",
          "settings": {
            "question": "Which watches qualify for trade-in?",
            "answer": "Any previous Carbinox smartwatch — X-Ranger, Vesta, Vortex, Blaze Type R, or Blaze Type S. Older models are eligible but you may be eligible for up to $50 trade-in value only."
          }
        },
        "faq_9Rhwj9": {
          "type": "faq",
          "settings": {
            "question": "How long do I have to ship my old watch?",
            "answer": "You must place your order for the new Carbinox Edge immediately after completing the trade-in application. Once your new watch ships, you'll receive instructions on where to send your old watch. We recommend shipping within 7 days of receiving your new watch."
          }
        },
        "faq_Q8qixE": {
          "type": "faq",
          "settings": {
            "question": "How is my credit amount determined?",
            "answer": "You choose your refund type during the application:\n•⁠  ⁠Store credit — you receive 50% more value (best deal)\n•⁠  ⁠Refund to original payment method — standard credit applied to your order\n\nThe credit amount is the same regardless of which Carbinox model you're trading in. Condition (like-new vs. used but working) may affect eligibility."
          }
        },
        "faq_kV7GgC": {
          "type": "faq",
          "settings": {
            "question": "Do I pay anything to ship the old watch back?",
            "answer": "No. We'll provide a prepaid return shipping label with your instructions. Shipping your old watch back is completely free."
          }
        },
        "faq_xqJkE9": {
          "type": "faq",
          "settings": {
            "question": "Can I trade in a watch from another brand?",
            "answer": "No. The trade-in program is exclusively for existing Carbinox smartwatch owners. Only Carbinox models qualify."
          }
        }
      },
