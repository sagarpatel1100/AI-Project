        "1660076465f1e811f4-1": {
          "type": "question",
          "disabled": true,
          "settings": {
            "title": "Are these smartwatches indestructible?",
            "answer": "<p>We guarantee you'll receive the stronger smartwatch you've ever had. However,don't submit it to abuse tests such as as throwing it from a 30th floor or test it with a saw to see if it holds up (This is a true story 🥴)</p>"
          }
        },
        "1660076465f1e811f4-2": {
          "type": "question",
          "settings": {
            "title": "CAN I ANSWER AND MAKE CALLS WITH THE CARBINOX VORTEX?",
            "answer": "<p>Yes, you can answer and dial calls with your Carbinox Vortex. Just pair it with your phone and make sure Bluetooth is on.</p>"
          }
        },
        "9e45f6ba-ce45-4182-ab2f-4f8bcd8f6681": {
          "type": "question",
          "settings": {
            "title": "CAN YOU VIEW AND REPLY TO TEXT MESSAGES WITH THE CARBINOX VORTEX?",
            "answer": "<p>You view read SMS or social media notifications on your Carbinox Vortex. However, you cannot reply. This high-cost feature could dramatically affect the costs of our products.</p>"
          }
        },
        "1660076465f1e811f4-4": {
          "type": "question",
          "settings": {
            "title": "IS THE CARBINOX VORTEX WATERPROOF?",
            "answer": "<p>Yes, the Carbinox Vortex is fully Waterproof with IP69K and 5ATM technology.</p>"
          }
        },
        "b94b4ba9-d47e-4003-8a27-597acb9b7952": {
          "type": "question",
          "settings": {
            "title": "IS MY SMARTPHONE COMPATIBLE WITH THE CARBINOX VORTEX?",
            "answer": "<p>Yes. The Carbinox Vortex works with any Apple or Android device through the GLORYFIT PRO APP.</p>"
          }
        },
        "91345035-5b96-4951-8a1e-d62883b97573": {
          "type": "question",
          "settings": {
            "title": "WILL THE CARBINOX VORTEX FIT MY WRIST?",
            "answer": "<p>Yes, all of our smartwatches come with adjustable bands that can fit any wrist.</p>"
          }
        },
        "b1b69a37-56f7-497e-b973-6abbf1bb8a51": {
          "type": "question",
          "settings": {
            "title": "DO YOU OFFER GUARANTEES?",
            "answer": "<p>Of course! All of our smartwatches are covered with 45-Day Risk Free Trial, and Lifetime Warranty in case they don't fit your needs or if you face any software or internal issues. If this happens, we'll provide you a replacement at no cost.</p>"
          }
        },
        "08cad6de-133a-438f-9a28-8990559de84f": {
          "type": "question",
          "settings": {
            "title": "HOW LONG DOES THE VORTEX TAKE TO FULLY CHARGE?",
            "answer": "<p>The Carbinox Vortex will be fully charged after approximately 90 minutes and lasts up to 14 days within a single cycle.</p>"
          }
        },
        "7c26ebf9-9f0f-4f89-a025-4868a8e8855f": {
          "type": "question",
          "disabled": true,
          "settings": {
            "title": "How can I contact Carbinox?",
            "answer": "<p>If you have any questions or doubts, please don't hesitate to send us an e-mail to <strong>info@shopcarbinox.com</strong> or through our social media channels such as Facebook or Instagram.</p>"
          }
        }
      },
