    "2f607819-cec8-412d-8e04-6609a7cb291d": {
      "type": "faq",
      "blocks": {
        "template--14757829345383__2f607819-cec8-412d-8e04-6609a7cb291d-question-1": {
          "type": "question",
          "settings": {
            "title": "My smartwatch is not turning on, what should I do?",
            "answer": "<p>Please connect your smartwatch to the usb charging cable and wait around 30-60 minutes to turn it on. If the problem persists, please try different charging docks and locations to ensure it’s a voltage issue or not.</p>"
          }
        },
        "template--14757829345383__2f607819-cec8-412d-8e04-6609a7cb291d-question-2": {
          "type": "question",
          "settings": {
            "title": "My smartwatch is not receiving SMS or notifications, what should I do?",
            "answer": "<p>Please verify if the smartwatch is fully connected to the app.</p><p><strong>NOTE: IF YOUR SMARTPHONE HAS THE “DON’T DISTURB” FEATURE ACTIVATED, SNOOZE MODE OR SILENT MODE, YOU MAY NOT RECEIVE ANY NOTIFICATIONS ON YOUR SMARTWATCH.</strong></p><p><strong>NOTE: If you close the app on background, you may not receive any notifications on your smartwatch.</strong></p><p><strong>NOTE: If you’re not allowing all permissions to use the app on your smartphone, you may not receive any notifications.</strong></p>"
          }
        },
        "template--14757829345383__2f607819-cec8-412d-8e04-6609a7cb291d-question-3": {
          "type": "question",
          "settings": {
            "title": "How can I find more watch faces?",
            "answer": "<p>Press and hold the main screen of your smartwatch for 3-5 seconds, then start swiping to the right to select another watch face. If you want more, please go to the app and then press “Watch Faces” or “Discover more dials”  so you can see all the ones we have available.</p>"
          }
        },
        "69dd1581-e137-4155-9fe5-a8d374a25650": {
          "type": "question",
          "settings": {
            "title": "I’m not receiving accurate tracking, what should I do?",
            "answer": "<p>Please make sure you completed your profile on the app, meaning exact weight, age, height, or any other information needed.</p><p>If the problem still persists, please reset your smartwatch to factory settings and try again.</p><p><strong>NOTE: TRACKING COULD HAVE 10% OR 15% OF INACCURACY DUE TO ENVIRONMENTS, MOTION, WRIST MOVEMENT, AND ALGORITHM CHANGES.</strong></p>"
          }
        },
        "1b29af93-99ea-46af-acd4-73d3a3b4befa": {
          "type": "question",
          "settings": {
            "title": "My smartwatch is not showing my heart rate, blood pressure, or any other tracking feature.",
            "answer": "<p>First of all, make sure your smartwatch is adjusted to your wrist properly to ensure the proper tracking. </p><p>If you’re an Apple user, you can also connect your smartwatch to the Health App to get een more accurate information.</p><p><strong>NOTE: TRACKING COULD HAVE 10% OR 15% OF INACCURACY DUE TO ENVIRONMENTS, MOTION, WRIST MOVEMENT, AND ALGORITHM CHANGES.</strong></p>"
          }
        },
        "d3174f5b-1eca-4a67-a949-d465f1022458": {
          "type": "question",
          "settings": {
            "title": "I’m seeing the temperature in Celsius instead of Fahrenheit.",
            "answer": "<p>Please go to your Carbinox App and then go to the Weather settings. You can easily change from Celsius to Fahrenheit and viceversa.</p>"
          }
        },
        "78dc08bc-ab5c-40ee-a987-86d2bf74078e": {
          "type": "question",
          "settings": {
            "title": "Weather is not showing on my smartwatch.",
            "answer": "<p>Please go to the Carbinox App and make sure you’ve registered the city you live in, so the system can show you the exact weather conditions.</p>"
          }
        },
        "1a207bf5-ab7f-45b2-9005-726b56a61e40": {
          "type": "question",
          "settings": {
            "title": "My battery doesn’t last more than 7 days, what should I do?",
            "answer": "<p>Please reduce the screen brightness on your smartwatch to preserve battery, as well as turning unnecessary notifications off, that will increase your battery life.</p><p>Also, the smartwatch comes with a battery saving feature. Please turn it on when needed.<br/><br/><strong>NOTE: PLEASE KEEP IN MIND THAT THE BLUETOOTH CALLING FEATURE COULD REDUCE THE BATTERY IF IT’S USED A LOT.</strong></p>"
          }
        },
        "6800f6c6-ce25-478a-9d67-773f69df8fde": {
          "type": "question",
          "settings": {
            "title": "My smartwatch is showing the time in 12-hour format or measuring in meters.",
            "answer": "<p>Both options can be changed on the Carbinox App by checking the settings on it. </p><p><strong>NOTE: IF YOUR SMARTPHONE EXPERIENCES NETWORK ISSUES OR IT’S DISCONNECTED FROM BLUETOOTH, THIS FEATURE MAY RESET.</strong></p>"
          }
        }
      },
