    "166007646669623aaa": {
      "type": "faq",
      "blocks": {
        "9e45f6ba-ce45-4182-ab2f-4f8bcd8f6681": {
          "type": "question",
          "settings": {
            "title": "CAN I ANSWER AND MAKE PHONE CALLS DIRECTLY FROM THE WATCH?",
            "answer": "<p>Yes. The Carbinox Edge includes a built-in speaker and microphone, allowing you to make and receive calls straight from your wrist when connected to your smartphone via Bluetooth. Perfect for hands-free communication on the job or on the move.</p>"
          }
        },
        "1660076465f1e811f4-4": {
          "type": "question",
          "settings": {
            "title": "DOES THE CARBINOX EDGE SUPPORT VOICE-ACTIVATED TEXTING?",
            "answer": "<p>Absolutely. With our upgraded AI voice assistant, you can send and receive SMS messages using voice commands — no typing needed, even with gloves on.</p>"
          }
        },
        "b94b4ba9-d47e-4003-8a27-597acb9b7952": {
          "type": "question",
          "settings": {
            "title": "IS THE WATCH WATERPROOF AND DUSTPROOF?",
            "answer": "<p>Yes — the Edge is rated 5ATM and IP69K waterproof, plus it’s dustproof, shockproof, and built to take on mud, oil, water, and extreme conditions. You can wear it confidently while swimming, on job sites, or in the rain.</p>"
          }
        },
        "91345035-5b96-4951-8a1e-d62883b97573": {
          "type": "question",
          "settings": {
            "title": "HOW LONG DOES THE BATTERY LAST?",
            "answer": "<p>The Carbinox Edge features a 500mAh pure cobalt battery with up to 14 days of battery life per charge, depending on usage. That means less charging and more doing.</p>"
          }
        },
        "question_BWzhqx": {
          "type": "question",
          "settings": {
            "title": "IS MY SMARTPHONE COMPATIBLE WITH THE CARBINOX EDGE?",
            "answer": "<p>Yes. The Edge syncs with both iOS and Android smartphones using the Carbinox MAX app. You’ll get full functionality including calls, messages, health tracking, and more.</p>"
          }
        },
        "question_tY9TMH": {
          "type": "question",
          "settings": {
            "title": "WILL THE CARBINOX EDGE FIT MY WRIST?",
            "answer": "<p>Yes. It comes with a universal 22mm strap and fits most wrist sizes from 150mm to 240mm. It also includes a removable strap system, so you can customize it however you want.</p>"
          }
        },
        "question_EjQURq": {
          "type": "question",
          "settings": {
            "title": "WHAT KIND OF JOBS AND ENVIRONMENTS IS THIS WATCH BUILT FOR?",
            "answer": "<p>The Carbinox Edge was built for hard workers: construction crews, mechanics, truckers, ranchers, firefighters, and outdoorsmen. It’s made to survive dirt, dust, drops, impact, and extreme heat/cold — and still keep ticking.</p>"
          }
        },
        "question_7UfMXf": {
          "type": "question",
          "settings": {
            "title": "HOW LONG DOES IT TAKE TO CHARGE?",
            "answer": "<p>It takes approximately 2 hours to fully charge using the included USB cable. You’ll get up to 2 weeks of power per charge.</p>"
          }
        },
        "question_dhdAHM": {
          "type": "question",
          "settings": {
            "title": "WHAT DOES THE LIFETIME WARRANTY ACTUALLY COVER?",
            "answer": "<p>Everything. If anything ever happens to your Carbinox Edge — damage, failure, wear, or tear — we’ll replace it at no cost, no questions asked. It’s part of our promise to back every hardworking man who puts our gear to the test.</p>"
          }
        },
        "question_U4WVJk": {
          "type": "question",
          "settings": {
            "title": "CAN I INSTALL THIRD-PARTY APPS LIKE SPOTIFY OR WHATSAPP?",
            "answer": "<p>No, the Carbinox Edge uses a closed system with pre-installed apps only. This ensures better performance, battery efficiency, and long-term reliability. Third-party apps such as Spotify or WhatsApp are not supported.</p>"
          }
        },
        "question_wdHLnX": {
          "type": "question",
          "settings": {
            "title": "CAN I REPLY TO WHATSAPP OR SOCIAL MEDIA MESSAGES FROM THE WATCH?",
            "answer": "<p>The Edge allows you to view notifications from messaging and social media platforms (e.g., WhatsApp, Facebook, Instagram). However, replying directly from the watch is not available at this time, aside from limited voice-to-text responses on Android via the Carbinox Max app.</p>"
          }
        },
        "question_w3bHXr": {
          "type": "question",
          "settings": {
            "title": "DOES THE GPS WORK INDEPENDENTLY, OR DOES IT NEED MY PHONE?",
            "answer": "<p>The Carbinox Edge features dual-band GNSS, allowing it to provide standalone GPS tracking without requiring a phone connection. This is especially useful for outdoor activities where phone signal may be weak or unavailable.</p>"
          }
        },
        "question_Vr3BGi": {
          "type": "question",
          "settings": {
            "title": "WILL THE HEALTH SENSORS WORK IF I HAVE TATTOOS ON MY WRIST?",
            "answer": "<p>In some cases, tattoos may interfere with the accuracy of optical sensors such as heart rate or blood oxygen monitors. This is a common limitation across all smartwatch brands, not specific to Carbinox.</p>"
          }
        },
        "question_3jwK3H": {
          "type": "question",
          "settings": {
            "title": "CAN I USE THE WATCH WITHOUT A SMARTPHONE OR APP?",
            "answer": "<p>Basic features like time, step tracking, and alarms will function without the app. However, for full access to GPS sync, watch face customization, health monitoring, and smart notifications, the Carbinox Max app is required.</p>"
          }
        },
        "question_7bzh9w": {
          "type": "question",
          "settings": {
            "title": "DOES THE EDGE SUPPORT WIRELESS CHARGING?",
            "answer": "<p>No, the Carbinox Edge uses a magnetic USB charging cable (included with your order). Wireless charging is not currently supported.</p>"
          }
        },
        "question_igc9jA": {
          "type": "question",
          "settings": {
            "title": "IS THE WATCH COMPATIBLE WITH RCS (GOOGLE MESSAGES)?",
            "answer": "<p>The Edge supports standard SMS notifications. However, RCS messages may not appear on the watch due to how Android handles RCS protocols. For optimal performance, switching to SMS-only mode is recommended.</p>"
          }
        },
        "question_RHHRkU": {
          "type": "question",
          "settings": {
            "title": "CAN I CHANGE THE TEMPERATURE UNITS FROM CELSIUS TO FAHRENHEIT?",
            "answer": "<p>Yes. In the Carbinox Max app, you can easily toggle between Celsius and Fahrenheit in the “Unit Settings” section.</p>"
          }
        },
        "question_d6E6Gh": {
          "type": "question",
          "settings": {
            "title": "DOES THE CARBINOX EDGE HAVE A BUILT-IN CAMERA?",
            "answer": "<p>No, the Edge does not include a camera. The focus of the device is on durability, reliability, and essential smart features tailored to performance — not entertainment.</p>"
          }
        }
      },
