        "liquid_9FYWef": {
          "type": "liquid",
          "name": "Badge Estimated",
          "settings": {
            "liquid": "<div class=\"variant-delivery-estimated\">\n<p>\n<span>Edge Phantom is selling fast! ⚡\n</span><br>\nExpect delivery in 10–15 business days.\n</p>\n</div>\n\n<style>\n.variant-delivery-estimated {\nbackground: #F3FFE8;\npadding: 2px 4px;\nmax-width: 278px;\nmargin: 15px auto 0px;\n}\n.variant-delivery-estimated p {\nmargin: 0px;\nfont-size: 12px;\nline-height: 120%;\ntext-align: center;\n}\n.variant-delivery-estimated span {\nfont-weight: 600;\ntext-transform: uppercase;\n}\n\n.product-guarantee-banner {\nmargin-top: 0px;\n}\n@media (max-width: 768px) {\n.product-guarantee-banner {\nmargin-top: -10px;\n}\n.variant-delivery-estimated {\nmargin: -5px auto 15px;\n}\n}\n</style>\n\n<script>\ndocument.addEventListener(\"DOMContentLoaded\", function() {\n  const checkReady = setInterval(() => {\n    const radios = document.querySelectorAll(\".block-swatch__radio\");\n    const banner = document.querySelector(\".variant-delivery-estimated\");\n\n    if (!radios.length || !banner) return;\n    clearInterval(checkReady);\n\n    function updateBanner() {\n      const selected = document.querySelector(\".block-swatch__radio:checked\");\n      const isArmorSilver = selected && selected.value === \"Phantom Black\";\n      banner.style.display = isArmorSilver ? \"\" : \"none\";\n    }\n\n    radios.forEach(radio => radio.addEventListener(\"change\", updateBanner));\n    updateBanner();\n  }, 500);\n});\n</script>"
          }
        },
