35/files/gift-2_601e3cd6-2654-4219-9078-5cbf565fe27b.png?v=1770838340\" alt=\"Limited Edition Straps\">\n        {% if settings.new-gift == true %}\n        <img width=\"100\" height=\"100\" class=\"sticker-img\" src=\"https://cdn.shopify.com/s/files/1/0049/0533/6935/files/sticker-x3.png?v=1774882774\" alt=\"sticker x3\">\n        {% endif %}\n      </div>\n      \n      <p>\n      {% if settings.new-gift == true %}\n      <span style=\"color: #D80027; font-weight: 600; margin-right: 3px;\">3X </span>\n      {% endif %}\n        USB Charger</p>\n    </div>\n    <div class=\"gift-item\">\n      <div class=\"gift-badge\">FREE</div>\n      <div style=\"position: relative; overflow: visible;\">\n        <img class=\"main-image__gift\" src=\"https://cdn.shopify.com/s/files/1/0049/0533/6935/files/gift-3.webp?v=1770837490\" alt=\"Tempered Glass Pack\">\n\n      </div>\n      <p>Mystery Gift</p>\n    </div>\n  </div>\n</div>\n\n\n<style>\n/* Hide default promo banner */\n\n\n#promo-banner {\n  display: none !important;\n}\n\n.guarantee-banner {\n  background: #f9f9f9 !important;\n}\n\n.free-gifts {\n  padding: 12px 15px;\n  background: #fff;\n  color: #000;\n  text-align: center;\n  border-radius: 5px;\n  border: 1px solid #F2F2F2;\n  margin: 0px auto;\n  max-width: 100%;\n}\n\n.gift-price {\n  font-weight: 500;\n  text-decoration: line-through;\n}\n.sticker-img{\n  position: absolute;\n  bottom: -3px;\n  right: -5px;\n  width: 25px;\n  height: 25px;\n}\n.free-gifts__header {\n  font-size: 18px;\n  font-weight: bold;\n  margin-bottom: 18px;\n  line-height: 2;\n}\n\np.free-gifts__header {\n  color: #000000 !important;\n}\n\n.free-gifts__items {\n  display: grid;\n  gap: 18px;\ngrid-template-columns: 1fr 1fr 1fr;\n  justify-content: center;\n  flex-wrap: nowrap;\n  align-items: flex-start;\nmargin-top: 15px;\n}\n\n.gift-item {\n  padding: 0px;\n  min-width: 0;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0px;\n  position: relative;\n}\n\n.gift-badge {\n  background: #06B036;\n  color: #fff;\n  font-weight: bold;\n  padding: 0px 4px;\n  border-radius: 4px;\n  font-size: 9px;\n  position: absolute;\n  top: -8px;\n  left: 50%;\n  transform: translateX(-50%);\n  white-space: nowrap;\n  z-index: 1;\n}\n{% if settings.promo-on %}\n.gift-badge {\n  background: #06B036;\n}\n{% endif %}\n\n.gift-item .main-image__gift {\n  flex: 0 0 1;\n  height: auto;\n  display: block;\n}\n\n.gift-item p {\n  font-size: 12px;\n  margin: 0;\n  font-weight: 400;\n  line-height: 1.2;\n  min-height: 30px;\n  display: flex;\n  align-items: center;\n  text-align: center;\n}\n\n.product-meta {\n  margin-top: 0px;\n  padding-bottom: 0px;\n  border: 0px;\n}\n\n.template-product .product-form__variants div.product-form__option-info {\n  justify-content: flex-start !important;\n}\n\ndiv.product-form__option-info {\n  justify-content: left !important;\n}\n\n/* Mobile styles */\n@media (max-width: 768px) {\n  .payments-badge-pdp {\n    margin-top: 5px;\n  }\n  .product-form__payment-container {\n    margin-bottom: 10px;\nmargin-top: 4px;\n  }\n  .product-form__variants{\n    margin-bottom: -10px;\n    margin-top: 15px;\n  }\n  .free-gifts {\n    padding: 10px 12px;\n  }\n  \n  .free-gifts__header {\n    font-size: 16px;\n    margin-bottom: 14px;\n  }\n \n  .gift-item p {\n    font-size: 10px;\n    min-height: 26px;\n  }\n  \n  .gift-badge {\n    font-size: 8px !important;\n    padding: 1px 3px;\n  }\n  \n\n  .free-gifts__items {\n    gap: 8px;\n  }\n\n  .sticker-img{\n    bottom: 0px;\n    right: -5px;\n    width: 20px;\n    height: 20px;\n  }\n}\n\n/* Desktop - mantener compacto */\n.shipping_polices_par {\nmargin-top: 10px;\n}\n@media (min-width: 769px) {\n.shipping_polices_par {\n}\n.payments-badge-pdp {\n  margin-top: 5px;\n}\n\n  .free-gifts {\n    max-width: 500px !important;\n    padding: 12px 20px;\n  }\n  \n  .free-gifts__header {\n    font-size: 20px;\n    margin-bottom: 20px;\n  }\n \n  \n  .gift-item p {\n    font-size: 13px;\n  }\n}\n</style>\n<script>\n  document.addEventListener(\"DOMContentLoaded\", function () {\n    // Generate dynamic date + 2 days for urgency\n    const dateEl = document.getElementById(\"today-date\");\n    if (dateEl) {\n      const today = new Date();\n      // Add 2 days to current date\n      today.setDate(today.getDate() );\n      const options = { month: \"long\", day: \"2-digit\" };\n      dateEl.textContent = today.toLocaleDateString(\"en-US\", options).toUpperCase();\n    }\n    \n    // Move banner to top of main element\n    const mainElement = document.getElementById(\"main\");\n    const bannerContainer = document.getElementById(\"free-gifts-banner\");\n    \n    if (!mainElement || !bannerContainer) {\n      console.error(\"main or free-gifts-banner container not found\");\n      return;\n    }\n    {% comment %}\nmainElement.insertBefore(bannerContainer, mainElement.firstChild);\n{% endcomment %}\n  });\n\n</script>"
