x === 1) {\n        valueEl.textContent = \"Ultimate Pack ($100 OFF)\";\n      }\n      valueEl.style.fontWeight = \"500\";\n    }\n  });\n\n  const swatchLabels = document.querySelectorAll(\"label.block-swatch__item\");\n\n  swatchLabels.forEach((label) => {\n    const text = label.textContent;\n\n    if (text.includes(\"Starter\")) {\n      label.setAttribute(\"data-pack\", \"starter-pack\");\n    }\n\n    if (text.includes(\"Ulti\")) {\n      label.setAttribute(\"data-pack\", \"ultimate-pack\");\n      label.textContent = \"Ultimate Pack\";\n    }\n\n    if (text.includes(\"Lite\")) {\n      label.setAttribute(\"data-pack\", \"double-pack\");\n    }\n\n    if (text.includes(\"Pack\")) {\n      const badge = document.createElement(\"span\");\n      badge.classList.add(\"save-badge\");\n      badge.textContent = text.includes(\"Lite Pack\") ? \"($100 OFF)\" :\n                          text.includes(\"Starter\") ? \"($50 OFF)\" : \"($150 OFF)\";\n\n      label.classList.add(\"pack-item\");\n      label.appendChild(badge);\n\n      if (text.includes(\"Ultimate Pack\")) {\n        const bestValueBadge = document.createElement(\"span\");\n        bestValueBadge.classList.add(\"best-value-badge\");\n        bestValueBadge.appendChild(document.createTextNode(\"MOST POPULAR 🔥\"));\n        label.appendChild(bestValueBadge);\n      }\n    }\n  });\n\nfunction detectWatchTypeAndUpdateText() {\n  const selectedRadio = document.querySelector('.block-swatch__radio:checked');\n  if (!selectedRadio) return;\n\n  const typeValue = selectedRadio.value.trim();\n  const formattedText =\n    typeValue.includes(\"Type S\")\n      ? '1 Carbinox Blaze Type S'\n      : typeValue.includes(\"Type R\")\n      ? '1 Carbinox Blaze Type R'\n      : '1 Carbinox Blaze';\n\n  // Modificar solo en packs visibles que NO sean double-pack\n  const visiblePackLists = document.querySelectorAll('.pack-list');\n  visiblePackLists.forEach(pack => {\n    if (pack.style.display === \"block\" && !pack.classList.contains(\"double-pack\")) {\n      const lis = pack.querySelectorAll('ul li .pack-li-content p:first-child');\n      lis.forEach(p => {\n        if (p.textContent.trim().startsWith(\"1 Carbinox Blaze\")) {\n          p.innerHTML = `<span class=\"icon\"></span>${formattedText}`;\n        }\n      });\n    }\n  });\n}\n\n  // Mostrar pack correspondiente y actualizar textos según tipo\n  function updatePackVisibility(selectedPack) {\n    const packs = document.querySelectorAll(\".pack-list\");\n    packs.forEach((pack) => {\n      if (pack.classList.contains(selectedPack)) {\n        pack.style.display = \"block\";\n      } else {\n        pack.style.display = \"none\";\n      }\n    });\n\n    // 👇 Muy importante: actualizar tipo de reloj solo después de mostrar\n    detectWatchTypeAndUpdateText();\n  }\n\n  // Detectar clic en swatches\n  const swatches = document.querySelectorAll(\"label.block-swatch__item[data-pack]\");\n  swatches.forEach((swatch) => {\n    swatch.addEventListener(\"click\", () => {\n      const selected = swatch.getAttribute(\"data-pack\");\n      updatePackVisibility(selected);\n    });\n  });\n// Escuchar cambios en el tipo de reloj (Type S / Type R)\ndocument.querySelectorAll('.block-swatch__radio').forEach(radio => {\n  radio.addEventListener('change', () => {\n    detectWatchTypeAndUpdateText();\n  });\n});\n  // Al seleccionar por primera vez\n  const firstSwatch = document.querySelector(\"label.block-swatch__item[data-pack]\");\n  if (firstSwatch) {\n    const firstRadio = firstSwatch.previousElementSibling;\n    if (firstRadio && firstRadio.type === 'radio') {\n      firstRadio.checked = true;\n      const selected = firstSwatch.getAttribute(\"data-pack\");\n      updatePackVisibility(selected);\n    }\n  }\n\n   const variantRadios = document.querySelectorAll(\n    '.block-swatch__radio[name=\"option1\"]'\n  );\n\n});\n</script>\n\n<style>\n.block-swatch{\nwidth: 100%;\n}\n.block-swatch:has(.pack-item) {\n  width: auto !important;