    "166007646669623aaa": {
      "type": "faq",
      "blocks": {
        "1660076465f1e811f4-1": {
          "type": "question",
          "settings": {
            "title": "Are these smartwatches indestructible?",
            "answer": "<p>We guarantee you'll receive the stronger smartwatch you've ever had. However,don't submit it to abuse tests such as as throwing it from a 30th floor or test it with a saw to see if it holds up <strong>(This is a true story 🥴).</strong></p>"
          }
        },
        "1660076465f1e811f4-2": {
          "type": "question",
          "settings": {
            "title": "Can I answer calls, send messages and speak with the Carbinox Smartwatches?",
            "answer": "<p>You can only REJECT OR FORWARD CALLS, as well as only READ messages and notifications.</p>"
          }
        },
        "1660076465f1e811f4-4": {
          "type": "question",
          "settings": {
            "title": "Are these smartwatches waterproof?",
            "answer": "<p>Our smartwatches are water resistant, which means that they’re able to be in contact with certain amount of water but <strong>we do not recommend to swim, dive or take a shower with them.</strong></p>"
          }
        },
        "b94b4ba9-d47e-4003-8a27-597acb9b7952": {
          "type": "question",
          "settings": {
            "title": "Do you offer guarantee on your products?",
            "answer": "<p>Of course! All our smartwatches are covered with 30-Day Money Back Guarantee in case that they don't fit your needs, as well as 30-Day Protection from any software or internal issues. If this happens, we'll provide you a replacement without cost.</p>"
          }
        },
        "91345035-5b96-4951-8a1e-d62883b97573": {
          "type": "question",
          "settings": {
            "title": "Is my smartphone compatible with any Carbinox Smartwatch?",
            "answer": "<p>Yes, you can connect any smartphone, whether it’s Android or Apple to your Carbinox Smartwatch via Bluetooth by using the app DAFIT (Available on App Store).</p>"
          }
        },
        "b1b69a37-56f7-497e-b973-6abbf1bb8a51": {
          "type": "question",
          "settings": {
            "title": "Will my wrist fit on the Carbinox watches?",
            "answer": "<p>Yes, all of our smartwatches have adjustable bands that can fit with any wrist.</p>"
          }
        },
        "08cad6de-133a-438f-9a28-8990559de84f": {
          "type": "question",
          "settings": {
            "title": "Do I need an app to use the Carbinox Smartwatches?",
            "answer": "<p>YES! You need to install the APP DAFIT and connect the watch to your smartphone via Bluetooth.</p>"
          }
        },
        "7c26ebf9-9f0f-4f89-a025-4868a8e8855f": {
          "type": "question",
          "settings": {
            "title": "How long does it take to charge fully?",
            "answer": "<p>Your smartwatch will be fully charged after approximately 2-3 hours.</p>"
          }
        },
        "1c978de2-39b0-45ac-824f-3346be21f7e9": {
          "type": "question",
          "settings": {
            "title": "How do I contact Carbinox?",
            "answer": "<p>If you have any questions or doubts, please don't hesitate to send us an e-mail to <strong>info@shopcarbinox.com</strong> or through our social media channels such as Facebook or Instagram.</p>"
          }
        }
      },
