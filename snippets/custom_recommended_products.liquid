  padding-bottom: 10px;
  position: relative;
    overflow-x: scroll;
    overflow-y: hidden;
}

.ymal-grid::-webkit-scrollbar {
  height: 6px;
}

.ymal-grid::-webkit-scrollbar-track {
  background: #eee;
}

.ymal-grid::-webkit-scrollbar-thumb {
  background: #999;
  border-radius: 4px;
    }


.ymal-card {
  flex: 0 0 75%;
  scroll-snap-align: start;
}

.ymal-arrow {
  position: absolute;
  top: 45%;
  transform: translateY(-50%);
  width: 20px;
  height: 20px;
  border-radius: 50%;
  border: none;
  background: white;
  cursor: pointer;
  z-index: 10;
  box-shadow: 0 2px 6px rgba(0,0,0,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ymal-prev {
  left: -5px;
}

.ymal-next {
  right: -5px;
}

@media (max-width: 768px){
.ymal-arrow {
  display: none;
}
}
</style>

<script>
document.addEventListener("click", function(e) {
  const wrapper = e.target.closest(".ymal-wrapper");
  if (!wrapper) return;

  const slider = wrapper.querySelector(".ymal-grid");
  if (!slider) return;

  const card = slider.querySelector(".ymal-card");
  if (!card) return;

  const cardWidth = card.offsetWidth;
  const gap = parseInt(getComputedStyle(slider).gap) || 0;
  const scrollAmount = cardWidth + gap;

  if (e.target.closest(".ymal-next")) {
    console.log("➡️ Next");
    slider.scrollBy({
      left: scrollAmount,
      behavior: "smooth"
    });
  }

  if (e.target.closest(".ymal-prev")) {
    console.log("⬅️ Prev");
    slider.scrollBy({
      left: -scrollAmount,
      behavior: "smooth"
    });
  }
});
</script>