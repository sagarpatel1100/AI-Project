
{% assign unique_id = section.id %}

<div class="reviews-slider-{{ unique_id }}">
  <div class="reviews-slider__wrapper-{{ unique_id }}">
    <div class="reviews-slider__container-{{ unique_id }}">
      {% for i in (1..3) %}
        {% assign key_name = 'name_review_pdp_' | append: i %}
        {% assign key_review = 'review_pdp_' | append: i %}
        {% assign key_date = 'date_review_pdp_' | append: i %}

        {% assign name_mf = product.metafields.custom[key_name] %}
        {% assign review_mf = product.metafields.custom[key_review] %}
        {% assign date_mf = product.metafields.custom[key_date] %}

        {% if name_mf and review_mf %}
          <div class="reviews-slider__item-{{ unique_id }}">
            {% if date_mf %}
              <p class="reviews-slider__date-left-{{ unique_id }}">{{ date_mf | metafield_text }}</p>
              <p class="reviews-slider__date-right-{{ unique_id }}">{{ date_mf | metafield_text }}</p>
            {% endif %}

            <div class="reviews-slider__card-{{ unique_id }}">
              <div style="display: flex;">
                <svg width="96" height="20" viewBox="0 0 96 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M9.55236 0L11.9271 6.28256L18.636 6.59963L13.3947 10.7995L15.1664 17.2781L9.55236 13.5912L3.93838 17.2781L5.71 10.7995L0.46875 6.59963L7.17765 6.28256L9.55236 0Z" fill="#FFC200"/>
                <path d="M28.6539 0.000244141L31.0287 6.2828L37.7376 6.59987L32.4963 10.7998L34.2679 17.2783L28.6539 13.5914L23.04 17.2783L24.8116 10.7998L19.5703 6.59987L26.2792 6.2828L28.6539 0.000244141Z" fill="#FFC200"/>
                <path d="M47.7556 0.000244141L50.1303 6.2828L56.8392 6.59987L51.5979 10.7998L53.3695 17.2783L47.7556 13.5914L42.1416 17.2783L43.9132 10.7998L38.6719 6.59987L45.3808 6.2828L47.7556 0.000244141Z" fill="#FFC200"/>
                <path d="M66.857 0.000244141L69.2317 6.2828L75.9406 6.59987L70.6994 10.7998L72.471 17.2783L66.857 13.5914L61.2431 17.2783L63.0147 10.7998L57.7734 6.59987L64.4823 6.2828L66.857 0.000244141Z" fill="#FFC200"/>
                <path d="M85.9586 0.000244141L88.3334 6.2828L95.0423 6.59987L89.801 10.7998L91.5726 17.2783L85.9586 13.5914L80.3447 17.2783L82.1163 10.7998L76.875 6.59987L83.5839 6.2828L85.9586 0.000244141Z" fill="#FFC200"/>
                </svg>
              </div>
              <div class="reviews-slider__text-{{ unique_id }}">
                {{ review_mf | metafield_text }}
              </div>
              <div class="reviews-slider__author-{{ unique_id }}" style="display: flex; align-items: center;">
                <span class="reviews-slider__icon-{{ unique_id }}" style="display: flex; align-items: center;">
                    <svg width="14" height="15" viewBox="0 0 14 15" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M8.42013 0.924561L6.64228 2.06569L4.86202 0.924561L3.8917 2.80265L1.77945 2.70401L1.87809 4.81546L0 5.78658L1.14113 7.56684L0 9.34469L1.87809 10.3158L1.77945 12.4273L3.8909 12.3286L4.86122 14.2067L6.64068 13.0656L8.42013 14.2083L9.39125 12.3302L11.5027 12.4289L11.4049 10.3174L13.2838 9.34469L12.1434 7.56684L13.2846 5.78739L11.4065 4.81707L11.5043 2.70562L9.39286 2.80345L8.42013 0.924561Z" fill="#FFC200"/>
                    <path d="M5.56978 9.79889L3.60028 7.83099C3.54357 7.77416 3.51172 7.69716 3.51172 7.61687C3.51172 7.53659 3.54357 7.45959 3.60028 7.40276L4.0285 6.97454C4.08533 6.91783 4.16233 6.88598 4.24261 6.88598C4.32289 6.88598 4.3999 6.91783 4.45672 6.97454L5.7839 8.30091L8.62589 5.45892C8.68272 5.40221 8.75972 5.37036 8.84 5.37036C8.92028 5.37036 8.99729 5.40221 9.05411 5.45892L9.48234 5.88714C9.53905 5.94397 9.57089 6.02097 9.57089 6.10125C9.57089 6.18153 9.53905 6.25853 9.48234 6.31536L5.99721 9.79889C5.94041 9.85535 5.86358 9.88705 5.7835 9.88705C5.70341 9.88705 5.62658 9.85535 5.56978 9.79889Z" fill="#1A1A1A"/>
                    </svg>
                    </span>
            {{ name_mf | metafield_tag }}
                </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <button class="reviews-slider__arrow-left-{{ unique_id }}" type="button"><svg width="7" height="11" viewBox="0 0 7 11" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M5.1826 10.3652L0 5.1826L5.1826 0L6.14854 0.965938L1.93187 5.1826L6.14854 9.39927L5.1826 10.3652Z" fill="white"/>
</svg>
</button>
  <button class="reviews-slider__arrow-right-{{ unique_id }}" type="button"><svg width="7" height="11" viewBox="0 0 7 11" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M4.21667 5.18261L0 0.965938L0.965937 0L6.14854 5.18261L0.965937 10.3652L0 9.39927L4.21667 5.18261Z" fill="white"/>
</svg>
</button>
</div>

<style>
.metafield-rich_text_field:empty,
.metafield-rich_text_field p:empty {
  display: none;
}
.metafield-rich_text_field p {
  line-height: 120%;
  text-align: left;
}
.reviews-slider-{{ unique_id }} {
  position: relative;
  margin: 0 auto;
  font-family: 'Poppins', sans-serif;
}

.reviews-slider__wrapper-{{ unique_id }} {
  overflow: hidden;
  width: 100%;
  position: relative;
}

.reviews-slider__container-{{ unique_id }} {
  display: flex;
  transition: transform 0.4s ease;
  width: 100%;
}

.reviews-slider__item-{{ unique_id }} {
  flex: 0 0 100%;
  position: relative;

}

.reviews-slider__card-{{ unique_id }} {
  box-sizing: border-box;
  padding: 20px;
  border: 1px solid black;
  border-radius: 10px;
  background: #fff;
  color: #505050;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 12px;
  height: 100%;
  justify-content: center;
}

.reviews-slider__stars-{{ unique_id }} {
  color: #FFC200;
  font-size: 22px;
  margin-bottom: 8px;
}

.reviews-slider__text-{{ unique_id }} {
  font-size: 14px;
  line-height: 130%;
  text-align: left;
  margin: 0px;
}

.reviews-slider__author-{{ unique_id }} {
  font-size: 14px;
  margin: 0px;
  color: black;
}

.reviews-slider__icon-{{ unique_id }} {
  color: #FFC200;
  margin-right: 4px;
}

/* === FECHAS A LOS COSTADOS === */
.reviews-slider__date-left-{{ unique_id }},
.reviews-slider__date-right-{{ unique_id }} {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  font-size: 13px;
  color: #777;
  font-weight: 400;
  white-space: nowrap;
}

.reviews-slider__date-left-{{ unique_id }} {
  left: -40px;
}

.reviews-slider__date-right-{{ unique_id }} {
  right: -40px;
}

/* === FLECHAS === */
.reviews-slider__arrow-left-{{ unique_id }},
.reviews-slider__arrow-right-{{ unique_id }} {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: black;
  color: white;
  border: none;
  width: 22px;
  height: 22px;
  border-radius: 50%;
  cursor: pointer;
  font-size: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.reviews-slider__arrow-left-{{ unique_id }} { left: -25px; }
.reviews-slider__arrow-right-{{ unique_id }} { right: -25px; }

.reviews-slider__arrow-left-{{ unique_id }}:hover,
.reviews-slider__arrow-right-{{ unique_id }}:hover {
  background: #333;
}


@media (max-width: 1000px) {
    .reviews-slider-{{ unique_id }} {
        max-width: calc(100vw - 80px);
    } 
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const id = '{{ unique_id }}';
  const container = document.querySelector(`.reviews-slider__container-${id}`);
  const cards = document.querySelectorAll(`.reviews-slider__item-${id}`);
  const next = document.querySelector(`.reviews-slider__arrow-right-${id}`);
  const prev = document.querySelector(`.reviews-slider__arrow-left-${id}`);

  if (!container || cards.length === 0) return;

  let index = 0;

  function updateSlider() {
    container.style.transform = `translateX(-${index * 100}%)`;
  }

  next?.addEventListener('click', () => {
    index = (index + 1) % cards.length;
    updateSlider();
  });

  prev?.addEventListener('click', () => {
    index = (index - 1 + cards.length) % cards.length;
    updateSlider();
  });
});
</script>
