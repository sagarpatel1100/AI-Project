  <style>
   .testimonial-card {
    padding: 24px 20px;
    border: 1px solid #EAEAEA;
    border-radius: 3px;
    background: white;
    max-width: 240px;
    margin: auto;
    text-align: left;
    font-family: 'Poppins', sans-serif;
  }
.testimonial-slider{
  max-width: 360px !important;
  width: 100%;
}
  .stars {
    color: #ffc107;
    font-size: 16px;
    margin: 0;
  }

  .quote {
    font-size: 13.67px;
    margin-bottom: 15px;
    margin-top: 4px;
    color: #0A3011;
    
  }

  .user-info {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .avatar {
    border-radius: 50%;
    width: 40px;
    height: 40px;
  }

  .user-info strong {
    font-size: 11px;
    font-weight: 600;
  }

  .user-info div {
    font-size: 11px;
    color: #0A3011;
  }

  .verified {
