      <script>
  window.onload = function () {
    const swiper = new Swiper('.testimonial-slider', {
      loop: true,
      navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev',
      },
    });
  };
</script>
