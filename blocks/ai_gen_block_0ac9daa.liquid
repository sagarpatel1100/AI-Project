{% doc %}
  @prompt
    Create a section where I can upload a picture of my logo. I just need the ability to place the logo as an image. Also, allow me to select the height of the section., Also allow me to define the size of the logo in px.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-logo-section-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: {{ block.settings.section_height }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-logo-wrapper-{{ ai_gen_id }} {
    max-width: 100%;
    max-height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .ai-logo-image-{{ ai_gen_id }} {
    max-width: {{ block.settings.logo_width }}px;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .ai-logo-placeholder-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    position: relative;
  }

  .ai-logo-placeholder-{{ ai_gen_id }} svg {
    max-width: 200px;
    max-height: 200px;
    width: 100%;
    height: auto;
    opacity: 0.3;
  }

  .ai-logo-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }
{% endstyle %}

<div class="ai-logo-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-logo-wrapper-{{ ai_gen_id }}">
    {% if block.settings.logo %}
      <img
        src="{{ block.settings.logo | image_url: width: 1200 }}"
        alt="{{ block.settings.logo.alt | escape }}"
        class="ai-logo-image-{{ ai_gen_id }}"
        loading="lazy"
        width="{{ block.settings.logo.width }}"
        height="{{ block.settings.logo.height }}"
      >
    {% else %}
      <div class="ai-logo-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-logo-empty-state-{{ ai_gen_id }}">
          Upload your logo
        </div>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Logo section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 800,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 200
    },
    {
      "type": "range",
      "id": "section_height",
      "min": 100,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Section height",
      "default": 300
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Logo section"
    }
  ],
  "tag": null
}
{% endschema %}
